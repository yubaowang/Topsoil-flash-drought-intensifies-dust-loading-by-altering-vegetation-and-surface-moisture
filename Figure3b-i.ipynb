def timer_msg(msg: str):
    print(f"\n{msg}")
    return time.time()


def done_msg(t0: float, msg: str = "Done"):
    print(f"{msg} | elapsed = {time.time() - t0:.1f} s")


def rebuild_event_table():
    required_files = [X_ALL_NPY, Y_ALL_NPY, FEAT_JSON, META_NPZ]

    for fp in required_files:
        if not os.path.exists(fp):
            raise FileNotFoundError(f"Missing code2 output file: {fp}")

    print("\nLoading code2 output files:")
    print(f"  X_all      = {X_ALL_NPY}")
    print(f"  y_all      = {Y_ALL_NPY}")
    print(f"  feat_names = {FEAT_JSON}")
    print(f"  meta       = {META_NPZ}")

    X_all = np.load(X_ALL_NPY).astype(np.float32, copy=False)
    y_all = np.load(Y_ALL_NPY).astype(np.float32, copy=False)

    with open(FEAT_JSON, "r", encoding="utf-8") as f:
        feature_names = json.load(f)

    meta = np.load(META_NPZ, allow_pickle=False)

    if X_all.ndim != 2:
        raise ValueError(f"X_all must be 2D, got shape={X_all.shape}")

    if X_all.shape[1] != len(feature_names):
        raise ValueError(
            f"Feature mismatch: X_all.shape[1]={X_all.shape[1]}, "
            f"len(feature_names)={len(feature_names)}"
        )

    if X_all.shape[0] != y_all.shape[0]:
        raise ValueError(
            f"Sample mismatch: X_all.shape[0]={X_all.shape[0]}, "
            f"y_all.shape[0]={y_all.shape[0]}"
        )

    df = pd.DataFrame(X_all, columns=feature_names)
    df["dod_event_mean"] = y_all

    if "lat_idx" in meta:
        df["lat_idx"] = meta["lat_idx"].astype(np.int32)
    if "lon_idx" in meta:
        df["lon_idx"] = meta["lon_idx"].astype(np.int32)
    if "event_lat" in meta:
        df["lat"] = meta["event_lat"].astype(np.float32)
    if "event_lon" in meta:
        df["lon"] = meta["event_lon"].astype(np.float32)

    print(f"\nLoaded event table from code2 output: {df.shape}")
    print(f"Features: {len(feature_names)}")
    print("Final features:")

    for i, f in enumerate(feature_names, 1):
        print(f"  {i:02d} {f}")

    return df


def load_or_build_event_table():
    if not FORCE_REBUILD_EVENT_TABLE and os.path.exists(EVENT_TABLE_CACHE):
        print(f"Loading cached event table: {EVENT_TABLE_CACHE}")
        df = joblib.load(EVENT_TABLE_CACHE)
        print(f"Cached event table shape: {df.shape}")
        return df

    t0 = timer_msg("=" * 80 + "\nLoading event table from code2 output...\n" + "=" * 80)
    df = rebuild_event_table()
    done_msg(t0, f"Event table loaded | shape={df.shape}")

    joblib.dump(df, EVENT_TABLE_CACHE)
    print(f"Saved event table cache: {EVENT_TABLE_CACHE}")

    return df


def load_fold_models():
    model_files = sorted(glob.glob(os.path.join(FOLD_MODEL_DIR, "*.joblib")))

    if not model_files:
        raise RuntimeError(f"No model files found in {FOLD_MODEL_DIR}")

    models = []
    feature_names_from_pack = None

    for fp in model_files:
        pack = joblib.load(fp)

        if isinstance(pack, dict):
            if "model" not in pack:
                raise KeyError(f"{fp} is a dict but missing key 'model'")

            model = pack["model"]

            if feature_names_from_pack is None and "feature_names" in pack:
                feature_names_from_pack = list(pack["feature_names"])
        else:
            model = pack

        if not hasattr(model, "predict"):
            raise TypeError(f"Loaded object has no predict(): {type(model)} | file={fp}")

        if hasattr(model, "n_jobs"):
            model.n_jobs = 1

        models.append(model)

    return models, model_files, feature_names_from_pack


def infer_feature_names(models, df_columns):
    for m in models:
        if hasattr(m, "feature_names_in_"):
            return list(m.feature_names_in_)

    feature_names = []

    for c in df_columns:
        if c in META_VARS:
            continue
        if c in {"event_id", "lat_idx", "lon_idx", "lat", "lon", "dod_event_mean"}:
            continue
        feature_names.append(c)

    if not feature_names:
        raise RuntimeError("Cannot infer feature names.")

    return feature_names


def load_or_build_models_and_features(df_columns):
    if not FORCE_RELOAD_MODELS and os.path.exists(MODEL_CACHE):
        print(f"Loading cached models/features: {MODEL_CACHE}")
        pack = joblib.load(MODEL_CACHE)
        return pack["models"], pack["model_files"], pack["feature_names"]

    t0 = timer_msg("Loading trained RF fold models...")
    models, model_files, feature_names_from_pack = load_fold_models()

    print(f"Loaded {len(models)} models")

    for fp in model_files:
        print("  ", os.path.basename(fp))

    if feature_names_from_pack is not None:
        feature_names = feature_names_from_pack
        print("\nUsing feature_names from saved joblib pack.")
    else:
        feature_names = infer_feature_names(models, df_columns)
        print("\nUsing inferred feature_names from event table.")

    done_msg(t0, "Models and feature names loaded")

    pack = {
        "models": models,
        "model_files": model_files,
        "feature_names": feature_names,
    }

    joblib.dump(pack, MODEL_CACHE)
    print(f"Saved model cache: {MODEL_CACHE}")

    return models, model_files, feature_names


def predict_all_models(models, X):
    preds = []

    for i, m in enumerate(models):
        if not hasattr(m, "predict"):
            raise TypeError(f"models[{i}] has no predict(); type={type(m)}")

        p = m.predict(X)
        preds.append(np.asarray(p, dtype=np.float32))

    return np.vstack(preds)


def bootstrap_response_curve(
    models,
    Xdf,
    feature_names,
    feat,
    grid_values,
    n_boot=300,
    boot_sample_size=3000,
    seed=42,
):
    rng = np.random.default_rng(seed)

    X_all = Xdf[feature_names].copy()
    n = len(X_all)

    if boot_sample_size is None or boot_sample_size > n:
        boot_sample_size = n

    mean_curve = np.full(len(grid_values), np.nan, dtype=np.float32)
    low_curve = np.full(len(grid_values), np.nan, dtype=np.float32)
    high_curve = np.full(len(grid_values), np.nan, dtype=np.float32)

    X_base = X_all.values.astype(np.float32, copy=True)
    feat_idx = feature_names.index(feat)

    for j, gv in enumerate(grid_values):
        X_mod = X_base.copy()
        X_mod[:, feat_idx] = np.float32(gv)

        pred_mat = predict_all_models(models, X_mod)
        pred_event_mean = pred_mat.mean(axis=0)

        boots = np.full(n_boot, np.nan, dtype=np.float32)

        for b in range(n_boot):
            idx = rng.integers(0, n, size=boot_sample_size)
            boots[b] = np.nanmean(pred_event_mean[idx])

        mean_curve[j] = np.nanmean(boots)
        low_curve[j] = np.nanpercentile(boots, 2.5)
        high_curve[j] = np.nanpercentile(boots, 97.5)

    return mean_curve, low_curve, high_curve


def get_grid_values(x, q=(0.01, 0.99), grid_size=80):
    x = np.asarray(x, dtype=np.float64)
    x = x[np.isfinite(x)]

    if x.size == 0:
        raise ValueError("Empty x after finite filter.")

    lo = np.quantile(x, q[0])
    hi = np.quantile(x, q[1])

    if not np.isfinite(lo) or not np.isfinite(hi):
        raise ValueError("Invalid quantile range.")

    if hi <= lo:
        lo = np.nanmin(x)
        hi = np.nanmax(x)

    if hi <= lo:
        hi = lo + 1e-6

    return np.linspace(lo, hi, grid_size).astype(np.float32)


def prepare_valid_dataframe(df, feature_names):
    missing_plot = [f for f in PLOT_FEATURES if f not in feature_names]

    if missing_plot:
        raise KeyError(f"PLOT_FEATURES not found in final feature_names: {missing_plot}")

    use_cols = feature_names + ["dod_event_mean"]
    valid = np.isfinite(df[use_cols]).all(axis=1)
    dff = df.loc[valid].copy().reset_index(drop=True)

    print(f"\nValid samples used for response curves: {len(dff):,}")

    if len(dff) > MAX_VALID_SAMPLES:
        dff = dff.sample(n=MAX_VALID_SAMPLES, random_state=RANDOM_SEED).reset_index(drop=True)
        print(f"Subsampled to {len(dff):,} events for speed.")

    return dff


def compute_all_response_curves(models, dff, feature_names):
    curve_dict = {
        "_meta": {
            "model_type": "RF",
            "model_out_dir": MODEL_OUT_DIR,
            "plot_features": list(PLOT_FEATURES),
            "feature_names": list(feature_names),
            "grid_size": GRID_SIZE,
            "n_boot": N_BOOT,
            "boot_sample_size": BOOT_SAMPLE_SIZE,
            "random_seed": RANDOM_SEED,
            "xrange_q": XRANGE_Q,
            "n_samples": int(len(dff)),
            "source": "code2_saved_X_y_feature_meta_outputs",
        }
    }

    n_panels = len(PLOT_FEATURES)

    for i, feat in enumerate(PLOT_FEATURES):
        print(f"\n[{i + 1}/{n_panels}] Computing: {feat}")

        x = dff[feat].values
        grid = get_grid_values(x, q=XRANGE_Q, grid_size=GRID_SIZE)

        t0 = time.time()

        mean_curve, low_curve, high_curve = bootstrap_response_curve(
            models=models,
            Xdf=dff,
            feature_names=feature_names,
            feat=feat,
            grid_values=grid,
            n_boot=N_BOOT,
            boot_sample_size=BOOT_SAMPLE_SIZE,
            seed=RANDOM_SEED + i,
        )

        print(f"  finished in {time.time() - t0:.1f} s")

        curve_dict[feat] = {
            "grid": grid.astype(np.float32),
            "mean_curve": mean_curve.astype(np.float32),
            "low_curve": low_curve.astype(np.float32),
            "high_curve": high_curve.astype(np.float32),
        }

    return curve_dict


def load_or_compute_curves(models=None, dff=None, feature_names=None):
    if not FORCE_RECOMPUTE_CURVES and os.path.exists(CURVE_CACHE):
        print(f"Loading cached RF response curves: {CURVE_CACHE}")
        return joblib.load(CURVE_CACHE)

    if models is None or dff is None or feature_names is None:
        raise ValueError("models, dff, feature_names are required when recomputing curves.")

    t0 = timer_msg("Computing RF response curves...")
    curve_dict = compute_all_response_curves(models, dff, feature_names)
    done_msg(t0, "All RF response curves computed")

    joblib.dump(curve_dict, CURVE_CACHE)
    print(f"Saved RF curve cache: {CURVE_CACHE}")

    return curve_dict


def apply_axis_settings(ax, feat):
    cfg = AXIS_SETTINGS.get(feat, {})

    if not cfg:
        return

    if cfg.get("xlim", None) is not None:
        ax.set_xlim(cfg["xlim"])
    if cfg.get("ylim", None) is not None:
        ax.set_ylim(cfg["ylim"])
    if cfg.get("xticks", None) is not None:
        ax.set_xticks(cfg["xticks"])
    if cfg.get("yticks", None) is not None:
        ax.set_yticks(cfg["yticks"])


def get_feature_color(feat: str) -> str:
    group = FEATURE_TO_GROUP.get(feat, "Other")
    return GROUP_COLORS.get(group, GROUP_COLORS["Other"])


def style_axis(ax, feat):
    ax.set_xlabel(FEATURE_LABELS.get(feat, feat), fontsize=X_LABEL_SIZE)
    ax.tick_params(axis="both", labelsize=TICK_LABEL_SIZE)
    ax.grid(False)
    apply_axis_settings(ax, feat)


def plot_from_curve_cache(curve_dict):
    n_panels = len(PLOT_FEATURES)
    ncols = N_COLS
    nrows = int(np.ceil(n_panels / ncols))

    fig, axes = plt.subplots(nrows, ncols, figsize=(FIG_W, FIG_H))
    axes = np.atleast_1d(axes).ravel()

    for i, feat in enumerate(PLOT_FEATURES):
        if feat not in curve_dict:
            raise KeyError(f"{feat} not found in curve cache.")

        ax = axes[i]

        grid = curve_dict[feat]["grid"]
        mean_curve = curve_dict[feat]["mean_curve"]
        low_curve = curve_dict[feat]["low_curve"]
        high_curve = curve_dict[feat]["high_curve"]

        color = get_feature_color(feat)

        ax.plot(grid, mean_curve, linewidth=LINE_WIDTH, color=color)
        ax.fill_between(grid, low_curve, high_curve, alpha=FILL_ALPHA, color=color)

        style_axis(ax, feat)

    for j in range(n_panels, len(axes)):
        fig.delaxes(axes[j])

    fig.supylabel(Y_LABEL, fontsize=Y_LABEL_SIZE, x=0.02)

    plt.tight_layout()

    if SAVE_FIG:
        out_png = os.path.join(PLOT_DIR, OUT_PNG_NAME)
        out_pdf = os.path.join(PLOT_DIR, OUT_PDF_NAME)

        plt.savefig(out_png, dpi=DPI, bbox_inches="tight")
        plt.savefig(out_pdf, dpi=DPI, bbox_inches="tight")

        print(f"\nSaved PNG: {out_png}")
        print(f"Saved PDF: {out_pdf}")

    if SHOW_ONLY:
        plt.show()

    plt.close(fig)


def main():
    print("=" * 80)
    print("RF response functions | Read code2 saved outputs directly")
    print("=" * 80)
    print(f"MODEL_OUT_DIR              = {MODEL_OUT_DIR}")
    print(f"FOLD_MODEL_DIR             = {FOLD_MODEL_DIR}")
    print(f"X_ALL_NPY                  = {X_ALL_NPY}")
    print(f"Y_ALL_NPY                  = {Y_ALL_NPY}")
    print(f"FEAT_JSON                  = {FEAT_JSON}")
    print(f"META_NPZ                   = {META_NPZ}")
    print(f"CACHE_DIR                  = {CACHE_DIR}")
    print(f"PLOT_DIR                   = {PLOT_DIR}")
    print(f"OUT_PNG_NAME               = {OUT_PNG_NAME}")
    print(f"OUT_PDF_NAME               = {OUT_PDF_NAME}")
    print(f"PLOT_ONLY_FROM_CACHE       = {PLOT_ONLY_FROM_CACHE}")
    print(f"FORCE_REBUILD_EVENT_TABLE  = {FORCE_REBUILD_EVENT_TABLE}")
    print(f"FORCE_RELOAD_MODELS        = {FORCE_RELOAD_MODELS}")
    print(f"FORCE_RECOMPUTE_CURVES     = {FORCE_RECOMPUTE_CURVES}")
    print("=" * 80)

    if PLOT_ONLY_FROM_CACHE and not FORCE_RECOMPUTE_CURVES and os.path.exists(CURVE_CACHE):
        print(f"\nFast plot mode from RF cache: {CURVE_CACHE}")
        curve_dict = joblib.load(CURVE_CACHE)
        plot_from_curve_cache(curve_dict)

        print("\n" + "=" * 80)
        print("DONE | RF plot from cache only")
        print("=" * 80)
        return

    df = load_or_build_event_table()
    models, model_files, feature_names = load_or_build_models_and_features(df.columns)

    print(f"\nNumber of features: {len(feature_names)}")

    for i, f in enumerate(feature_names, 1):
        print(f"  {i:02d} {f}")

    dff = prepare_valid_dataframe(df, feature_names)

    curve_dict = load_or_compute_curves(
        models=models,
        dff=dff,
        feature_names=feature_names,
    )

    plot_from_curve_cache(curve_dict)

    gc.collect()

    print("\n" + "=" * 80)
    print("DONE | RF response functions from code2 output")
    print("=" * 80)


if __name__ == "__main__":
    main()