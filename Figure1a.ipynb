import os
import numpy as np
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
import xarray as xr
from matplotlib.colors import LinearSegmentedColormap, BoundaryNorm
from matplotlib.patches import Circle

FILE_PATH_1 = r"L:\FD_Data_Process\FD_DOD_Filtered_05Std_Filtered\Average\dod_event_multiyear_mean_from_v5p2_FINAL_filtered.nc"
FILE_PATH_2 = r"L:\FD_Data_Process\FD_HighWind_DOD\Average\dod_event_multiyear_mean_with_climatology.nc"
MASK_PATH = r"M:\ERA5_land_sea_mask\ERA5_land_sea_mask_fixed_0.1deg.nc"

OUTPUT_DIR = r"L:\FD_Data_Process\Figures\闪旱期间DOD异常值"
OUTPUT_PNG = "闪旱事件_dod_percentage_change_final_with_latprofile_CI.png"

COARSEN_FACTOR = 3
LAT_SMOOTH_WINDOW = 5

USE_MANUAL_XLIM = True
XMIN = -10
XMAX = 30

SAVE_FIG = True
SAVE_DPI = 300

ds1 = xr.open_dataset(FILE_PATH_1)
ds2 = xr.open_dataset(FILE_PATH_2)

data1 = ds1["complete_dod_mean_mean"]
data2 = ds2["complete_dod_mean_climatology_mean"]

print(f"data1 的维度: {data1.dims}")
print(f"data1 的坐标: {list(data1.coords.keys())}")

print("正在读取陆地掩码...")
ds_mask = xr.open_dataset(MASK_PATH)
print(f"掩码文件中的变量: {list(ds_mask.variables.keys())}")

if "lsm" in ds_mask.variables:
    land_sea_mask = ds_mask["lsm"]
elif "mask" in ds_mask.variables:
    land_sea_mask = ds_mask["mask"]
elif "land_sea_mask" in ds_mask.variables:
    land_sea_mask = ds_mask["land_sea_mask"]
else:
    print("请确认掩码变量名，可用变量：", list(ds_mask.data_vars))
    land_sea_mask = ds_mask[list(ds_mask.data_vars)[0]]

lat_names = ["latitude", "lat", "y"]
lon_names = ["longitude", "lon", "x"]

lat_dim = next((name for name in lat_names if name in data1.dims), None)
lon_dim = next((name for name in lon_names if name in data1.dims), None)

if lat_dim is None or lon_dim is None:
    raise ValueError(f"无法识别纬度或经度维度: {data1.dims}")

print(f"检测到的维度名称 - 纬度: {lat_dim}, 经度: {lon_dim}")

mask_lat_dim = next((name for name in lat_names if name in land_sea_mask.dims), None)
mask_lon_dim = next((name for name in lon_names if name in land_sea_mask.dims), None)

if mask_lat_dim is None or mask_lon_dim is None:
    raise ValueError(f"无法识别掩码纬度或经度维度: {land_sea_mask.dims}")

print(f"掩码的维度名称 - 纬度: {mask_lat_dim}, 经度: {mask_lon_dim}")

if land_sea_mask.shape != data1.shape:
    print(f"掩码形状 {land_sea_mask.shape} 与数据形状 {data1.shape} 不同，正在插值...")
    land_sea_mask = land_sea_mask.interp(
        **{
            mask_lat_dim: data1[lat_dim],
            mask_lon_dim: data1[lon_dim],
        },
        method="nearest",
    )

print("计算百分比变化...")

values1 = data1.values
values2 = data2.values
lats = data1[lat_dim].values
lons = data1[lon_dim].values

with np.errstate(divide="ignore", invalid="ignore"):
    percentage_values = values1 / values2 * 100

percentage_change = xr.DataArray(
    percentage_values,
    coords={lat_dim: lats, lon_dim: lons},
    dims=[lat_dim, lon_dim],
    name="percentage_change",
)

print(f"✓ 原始数据计算完成，shape: {percentage_change.shape}")
print(f"正在进行{COARSEN_FACTOR}×{COARSEN_FACTOR}网格重采样...")

percentage_change_resampled = percentage_change.coarsen(
    {lat_dim: COARSEN_FACTOR, lon_dim: COARSEN_FACTOR},
    boundary="trim",
).mean()

land_sea_mask_resampled = land_sea_mask.coarsen(
    {mask_lat_dim: COARSEN_FACTOR, mask_lon_dim: COARSEN_FACTOR},
    boundary="trim",
).mean()

land_mask = land_sea_mask_resampled.values > 0.5
data_values = percentage_change_resampled.values
data_values_clean = np.where(np.isinf(data_values), np.nan, data_values)

print(f"✓ 重采样后 shape: {percentage_change_resampled.shape}")
print(f"陆地像素数: {land_mask.sum():,}")

land_pixels = land_mask.sum()
land_data = data_values_clean[land_mask]
land_valid_data = land_data[~np.isnan(land_data)]
land_nan_count = np.sum(np.isnan(land_data))

positive_count = np.sum(land_valid_data > 0)
negative_count = np.sum(land_valid_data < 0)
zero_count = np.sum(land_valid_data == 0)

positive_pct = positive_count / land_pixels * 100 if land_pixels > 0 else np.nan
negative_pct = negative_count / land_pixels * 100 if land_pixels > 0 else np.nan
zero_pct = zero_count / land_pixels * 100 if land_pixels > 0 else np.nan
nan_pct = land_nan_count / land_pixels * 100 if land_pixels > 0 else np.nan

data_no_nan = data_values_clean[~np.isnan(data_values_clean)]

print(f"数据实际范围: [{np.nanmin(data_no_nan):.2f}%, {np.nanmax(data_no_nan):.2f}%]")

data_resampled_da = xr.DataArray(
    data_values_clean,
    coords={
        lat_dim: percentage_change_resampled[lat_dim].values,
        lon_dim: percentage_change_resampled[lon_dim].values,
    },
    dims=[lat_dim, lon_dim],
)

mask_resampled_da = xr.DataArray(
    land_mask,
    coords={
        lat_dim: percentage_change_resampled[lat_dim].values,
        lon_dim: percentage_change_resampled[lon_dim].values,
    },
    dims=[lat_dim, lon_dim],
)

land_only_da = data_resampled_da.where(mask_resampled_da)

lat_mean = land_only_da.mean(dim=lon_dim, skipna=True)
lat_std = land_only_da.std(dim=lon_dim, skipna=True)
lat_n = land_only_da.count(dim=lon_dim)

lat_se = lat_std / np.sqrt(lat_n.where(lat_n > 0))
lat_ci = 1.96 * lat_se

if LAT_SMOOTH_WINDOW > 1:
    lat_mean = lat_mean.rolling({lat_dim: LAT_SMOOTH_WINDOW}, center=True, min_periods=1).mean()
    lat_ci = lat_ci.rolling({lat_dim: LAT_SMOOTH_WINDOW}, center=True, min_periods=1).mean()

lat_vals = lat_mean[lat_dim].values
profile_vals = lat_mean.values
ci_vals = lat_ci.values

profile_low = profile_vals - ci_vals
profile_high = profile_vals + ci_vals

plt.rcParams.update({
    "font.family": "Arial",
    "font.size": 12,
    "axes.linewidth": 1.0,
    "axes.labelsize": 14,
    "xtick.labelsize": 11,
    "ytick.labelsize": 11,
    "legend.fontsize": 11,
    "figure.dpi": 300,
})

boundaries = np.arange(-30, 31, 5)
colors = [
    "#08519c", "#3182bd", "#6baed6", "#9ecae1", "#c6dbef", "#deebf7",
    "#fee0d2", "#fcbba1", "#fc9272", "#fb6a4a", "#de2d26", "#a50f15",
]

diverging_cmap = LinearSegmentedColormap.from_list("diverging", colors, N=len(colors))
norm = BoundaryNorm(boundaries, ncolors=len(colors), clip=True)
diverging_cmap.set_bad(color="white", alpha=0.0)

fig = plt.figure(figsize=(14.5, 7.2), facecolor="white")

ax_main = fig.add_axes([0.05, 0.18, 0.70, 0.69], projection=ccrs.Robinson())
ax_lat = fig.add_axes([0.75, 0.18, 0.15, 0.69])
cax = fig.add_axes([0.11, 0.11, 0.53, 0.042])
ax_donut = fig.add_axes([0.08, 0.33, 0.16, 0.22])
ax_bar = fig.add_axes([0.50, 0.29, 0.09, 0.22])

im = ax_main.pcolormesh(
    percentage_change_resampled[lon_dim],
    percentage_change_resampled[lat_dim],
    data_values_clean,
    transform=ccrs.PlateCarree(),
    cmap=diverging_cmap,
    norm=norm,
    shading="auto",
)

ax_main.add_feature(cfeature.COASTLINE, linewidth=0.6, color="black")
ax_main.add_feature(cfeature.BORDERS, linewidth=0.25, color="gray")
ax_main.add_feature(cfeature.OCEAN, color="white", alpha=1.0)
ax_main.set_global()

gl = ax_main.gridlines(draw_labels=False, linewidth=0.35, color="gray", alpha=0.35)
gl.xlines = True
gl.ylines = True

ax_main.text(
    0.02,
    0.98,
    "a",
    transform=ax_main.transAxes,
    fontsize=28,
    fontweight="bold",
    va="top",
    ha="left",
)

cbar = fig.colorbar(im, cax=cax, orientation="horizontal", extend="both")
cbar.set_label(
    "Relative DOD Anomaly (%)\n(Anomaly vs. Climatology)",
    fontsize=16,
)
cbar.set_ticks(boundaries)
cbar.ax.tick_params(labelsize=16, width=1.0, length=6)

profile_pos = np.where(profile_vals > 0, profile_vals, np.nan)
profile_neg = np.where(profile_vals < 0, profile_vals, np.nan)

neg_low = np.where(profile_vals < 0, profile_low, np.nan)
neg_high = np.where(profile_vals < 0, np.minimum(profile_high, 0), np.nan)

pos_low = np.where(profile_vals > 0, np.maximum(profile_low, 0), np.nan)
pos_high = np.where(profile_vals > 0, profile_high, np.nan)

ax_lat.fill_betweenx(lat_vals, neg_low, neg_high, color="#2b8cbe", alpha=0.20, linewidth=0)
ax_lat.fill_betweenx(lat_vals, pos_low, pos_high, color="#d7301f", alpha=0.20, linewidth=0)

cross_mask = (profile_low < 0) & (profile_high > 0)
cross_neg = np.where(cross_mask, profile_low, np.nan)
cross_pos = np.where(cross_mask, profile_high, np.nan)

ax_lat.fill_betweenx(lat_vals, cross_neg, 0, color="#2b8cbe", alpha=0.20, linewidth=0)
ax_lat.fill_betweenx(lat_vals, 0, cross_pos, color="#d7301f", alpha=0.20, linewidth=0)

ax_lat.plot(profile_neg, lat_vals, color="#2b8cbe", linewidth=2.2)
ax_lat.plot(profile_pos, lat_vals, color="#d7301f", linewidth=2.2)

ax_lat.axvline(0, color="gray", linestyle="--", linewidth=1.2, alpha=0.7)

if USE_MANUAL_XLIM:
    ax_lat.set_xlim(XMIN, XMAX)
else:
    xmax = np.nanmax(np.abs(np.r_[profile_low, profile_high]))
    xmax = np.ceil(xmax / 5) * 5
    xmax = max(xmax, 10)
    ax_lat.set_xlim(-xmax, xmax)

ax_lat.set_ylim(-60, 90)
ax_lat.set_xlabel("Relative DOD Anomaly (%)\n(Anomaly vs. Climatology)", fontsize=14)
ax_lat.set_ylabel("Latitude (deg)", fontsize=16, rotation=270, labelpad=22)
ax_lat.yaxis.set_label_position("right")
ax_lat.yaxis.tick_right()
ax_lat.set_yticks([-60, -45, -30, -15, 0, 15, 30, 45, 60, 75, 90])

ax_lat.spines["top"].set_visible(False)
ax_lat.spines["left"].set_visible(False)
ax_lat.spines["right"].set_linewidth(1.0)
ax_lat.spines["bottom"].set_linewidth(1.0)

ax_lat.tick_params(axis="both", labelsize=16, width=1.0, length=5)
ax_lat.grid(False)

categories = ["Positive", "Negative", "Zero", "No Data"]
counts = [positive_count, negative_count, zero_count, land_nan_count]
percentages = [positive_pct, negative_pct, zero_pct, nan_pct]
donut_colors = ["#d6604d", "#4393c3", "#f7f7f7", "#cccccc"]

label_threshold = 1.0
valid_idx = [i for i, p in enumerate(percentages) if p >= label_threshold]

filtered_counts = [counts[i] for i in valid_idx]
filtered_categories = [categories[i] for i in valid_idx]
filtered_colors = [donut_colors[i] for i in valid_idx]
filtered_percentages = [percentages[i] for i in valid_idx]

wedges, _ = ax_donut.pie(
    filtered_counts,
    startangle=90,
    colors=filtered_colors,
    labels=None,
    wedgeprops=dict(width=0.45, edgecolor="none", linewidth=0),
)

outer_circle = Circle((0, 0), 1.0, fill=False, edgecolor="white", linewidth=2.2, zorder=10)
inner_circle = Circle((0, 0), 0.55, fill=False, edgecolor="white", linewidth=2.2, zorder=10)

ax_donut.add_patch(outer_circle)
ax_donut.add_patch(inner_circle)

ax_donut.text(0, 0, "Land\nOnly", ha="center", va="center", fontsize=12)
ax_donut.set_title("Data Distribution", fontsize=14, pad=16)

for wedge, category, pct in zip(wedges, filtered_categories, filtered_percentages):
    angle = 0.5 * (wedge.theta1 + wedge.theta2)

    x0 = 0.76 * np.cos(np.radians(angle))
    y0 = 0.76 * np.sin(np.radians(angle))
    x1 = 1.22 * np.cos(np.radians(angle))
    y1 = 1.22 * np.sin(np.radians(angle))

    ax_donut.plot([x0, x1], [y0, y1], color="black", linewidth=1.0, alpha=0.7)

    if np.cos(np.radians(angle)) >= 0:
        xt = x1 + 0.05
        ha = "left"
    else:
        xt = x1 - 0.05
        ha = "right"

    ax_donut.text(
        xt,
        y1,
        f"{category}\n{pct:.1f}%",
        ha=ha,
        va="center",
        fontsize=10,
    )

ax_donut.set_aspect("equal")

positive_data = data_no_nan[data_no_nan > 0]
negative_data = data_no_nan[data_no_nan < 0]

positive_mean = np.mean(positive_data) if len(positive_data) > 0 else 0
negative_mean = np.mean(negative_data) if len(negative_data) > 0 else 0

categories_bar = ["Neg.", "Pos."]
means = [negative_mean, positive_mean]
colors_bar = ["#2166ac", "#d6604d"]

bars = ax_bar.bar(
    categories_bar,
    means,
    color=colors_bar,
    alpha=0.8,
    edgecolor="black",
    linewidth=1.0,
    width=0.72,
)

for bar, mean_val in zip(bars, means):
    h = bar.get_height()
    ax_bar.text(
        bar.get_x() + bar.get_width() / 2,
        h + (0.5 if h >= 0 else -0.5),
        f"{mean_val:.2f}%",
        ha="center",
        va="bottom" if h >= 0 else "top",
        fontsize=10,
    )

ax_bar.axhline(0, color="black", linewidth=1.0)
ax_bar.set_ylabel("Mean", fontsize=12)
ax_bar.set_ylim(-13, 18)
ax_bar.set_yticks([])
ax_bar.tick_params(axis="x", labelsize=11, width=1.0, length=4)
ax_bar.grid(True, axis="y", alpha=0.25)

for spine in ax_bar.spines.values():
    spine.set_linewidth(1.0)

os.makedirs(OUTPUT_DIR, exist_ok=True)
out_png = os.path.join(OUTPUT_DIR, OUTPUT_PNG)

if SAVE_FIG:
    plt.savefig(out_png, dpi=SAVE_DPI, bbox_inches="tight", facecolor="white")

plt.show()

ds1.close()
ds2.close()
ds_mask.close()

print("\n========== 数据概况 ==========")
print(f"文件1数据范围: [{np.nanmin(values1):.4f}, {np.nanmax(values1):.4f}]")
print(f"文件2数据范围: [{np.nanmin(values2):.4f}, {np.nanmax(values2):.4f}]")
print(f"百分比变化范围: [{np.nanmin(data_values_clean):.2f}%, {np.nanmax(data_values_clean):.2f}%]")

print("\n========== 正负值统计 ==========")
print(f"负值平均值: {negative_mean:.2f}% (n={len(negative_data):,})")
print(f"正值平均值: {positive_mean:.2f}% (n={len(positive_data):,})")
print(f"正值占比: {100 * len(positive_data) / (len(positive_data) + len(negative_data)):.2f}%")
print(f"负值占比: {100 * len(negative_data) / (len(positive_data) + len(negative_data)):.2f}%")