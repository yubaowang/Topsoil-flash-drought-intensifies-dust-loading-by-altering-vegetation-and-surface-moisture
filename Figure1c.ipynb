#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import numpy as np
import xarray as xr
import matplotlib.pyplot as plt
from matplotlib.colors import TwoSlopeNorm


def align_to_common_grid(da1, da2, da3):
    return xr.align(da1, da2, da3, join="inner")


def compute_binned_mean(x, y, z, x_bins, y_bins):
    mask = np.isfinite(x) & np.isfinite(y) & np.isfinite(z)
    x, y, z = x[mask], y[mask], z[mask]

    if x.size == 0:
        raise ValueError("没有有效样本，无法进行二维分箱绘图。")

    counts, _, _ = np.histogram2d(y, x, bins=[y_bins, x_bins])
    z_sum, _, _ = np.histogram2d(y, x, bins=[y_bins, x_bins], weights=z)

    with np.errstate(invalid="ignore", divide="ignore"):
        z_mean = z_sum / counts

    z_mean[counts == 0] = np.nan
    return z_mean, counts


def compute_relative_anomaly_percent(data_anom, data_clim, min_denom=1e-6):
    denom = xr.where(np.abs(data_clim) >= min_denom, data_clim, np.nan)
    return data_anom / denom * 100.0


def main():
    wind_file = r"L:\FD_Data_Process\FD_Wind\Wind_Drought_WindMean_Value_v5.3\Average\windmean_event_multiyear_mean_from_v5p3_fortran.nc"
    evi_file = r"L:\FD_Data_Process\FD_EVI\Wind_Drought_EVI_Value_v5.2_fortran_pentad\Average\evi_event_multiyear_mean_from_v5p2_fortran_pentad.nc"
    file_path_1 = r"L:\FD_Data_Process\FD_DOD_Filtered_05Std_Filtered\Average\dod_event_multiyear_mean_from_v5p2_FINAL_filtered.nc"
    file_path_2 = r"L:\FD_Data_Process\FD_HighWind_DOD\Average\dod_event_multiyear_mean_with_climatology.nc"

    x_var = "complete_wind_mean_mean_mean"
    y_var = "complete_evi_mean_mean"
    z_anom_var = "complete_dod_mean_mean"
    z_clim_var = "complete_dod_mean_climatology_mean"

    COLOR_VMIN = -24
    COLOR_VMAX = 24
    COLOR_TICK_STEP = 6

    output_dir = r"L:\FD_Data_Process\Figures\闪旱期间DOD异常值"
    os.makedirs(output_dir, exist_ok=True)
    output_file = os.path.join(output_dir, "wind_evi_dod_relative_anomaly_binned.png")

    print("读取数据...")
    ds_wind = xr.open_dataset(wind_file)
    ds_evi = xr.open_dataset(evi_file)
    ds1 = xr.open_dataset(file_path_1)
    ds2 = xr.open_dataset(file_path_2)

    try:
        checks = [
            (x_var, ds_wind, wind_file),
            (y_var, ds_evi, evi_file),
            (z_anom_var, ds1, file_path_1),
            (z_clim_var, ds2, file_path_2),
        ]

        for var, ds, path in checks:
            if var not in ds:
                raise KeyError(f"{path} 中不存在变量: {var}")

        da_x = ds_wind[x_var]
        da_y = ds_evi[y_var]
        data1 = ds1[z_anom_var]
        data2 = ds2[z_clim_var]

        print("计算 DOD anomaly 相对 climatology 的百分比...")
        da_z = compute_relative_anomaly_percent(data1, data2, min_denom=1e-6)

        print("对齐共同网格...")
        da_x, da_y, da_z = align_to_common_grid(da_x, da_y, da_z)

        x = da_x.values.ravel()
        y = da_y.values.ravel()
        z = da_z.values.ravel()

        valid_mask = np.isfinite(x) & np.isfinite(y) & np.isfinite(z)
        x_valid = x[valid_mask]
        y_valid = y[valid_mask]
        z_valid = z[valid_mask]

        if x_valid.size == 0:
            raise ValueError("三个变量共同有效样本数为 0，无法绘图。")

        print(f"共同有效样本数: {x_valid.size:,}")
        print(f"{x_var} 范围: [{np.nanmin(x_valid):.4f}, {np.nanmax(x_valid):.4f}]")
        print(f"{y_var} 范围: [{np.nanmin(y_valid):.4f}, {np.nanmax(y_valid):.4f}]")
        print(f"DOD relative anomaly percent 范围: [{np.nanmin(z_valid):.4f}, {np.nanmax(z_valid):.4f}] %")

        nx = 200
        ny = 200

        x_min, x_max = np.nanmin(x_valid), np.nanmax(x_valid)
        y_min, y_max = np.nanmin(y_valid), np.nanmax(y_valid)

        x_pad = 0.02 * (x_max - x_min) if x_max > x_min else 0.1
        y_pad = 0.02 * (y_max - y_min) if y_max > y_min else 0.01

        x_bins = np.linspace(x_min - x_pad, x_max + x_pad, nx + 1)
        y_bins = np.linspace(y_min - y_pad, y_max + y_pad, ny + 1)

        print("进行二维分箱统计...")
        z_mean, counts = compute_binned_mean(x_valid, y_valid, z_valid, x_bins, y_bins)

        z_mean[counts < 5] = np.nan

        if z_mean[np.isfinite(z_mean)].size == 0:
            raise ValueError("分箱后无有效数据可显示。")

        print(f"非空箱体数: {np.sum(np.isfinite(z_mean)):,}")
        print(f"总箱体数: {z_mean.size:,}")

        vmin = COLOR_VMIN
        vmax = COLOR_VMAX
        z_plot = np.clip(z_mean, vmin, vmax)

        print(f"原始分箱后范围: [{np.nanmin(z_mean):.4f}, {np.nanmax(z_mean):.4f}] %")
        print(f"手动固定显示范围: [{vmin:.4f}, {vmax:.4f}] %")

        plt.rcParams.update({
            "font.family": "Arial",
            "font.size": 12,
            "axes.labelsize": 22,
            "axes.linewidth": 1.2,
            "xtick.labelsize": 20,
            "ytick.labelsize": 20,
            "xtick.direction": "out",
            "ytick.direction": "out",
            "xtick.major.size": 5,
            "ytick.major.width": 1.2,
            "xtick.major.width": 1.2,
            "ytick.major.size": 5,
            "pdf.fonttype": 42,
            "ps.fonttype": 42,
        })

        cmap = plt.get_cmap("RdBu_r").copy()
        cmap.set_bad(color="white")
        norm = TwoSlopeNorm(vmin=vmin, vcenter=0.0, vmax=vmax)

        fig = plt.figure(figsize=(8.8, 6.4), dpi=300)
        ax = fig.add_axes([0.10, 0.12, 0.72, 0.80])
        cax = fig.add_axes([0.66, 0.41, 0.03, 0.5])

        mesh = ax.pcolormesh(
            x_bins,
            y_bins,
            z_plot,
            cmap=cmap,
            norm=norm,
            shading="flat",
            rasterized=True,
        )

        ax.set_xlabel("Mean wind speed (m s$^{-1}$)")
        ax.set_ylabel("Mean EVI")

        for side in ["left", "right", "top", "bottom"]:
            ax.spines[side].set_visible(True)
            ax.spines[side].set_linewidth(1.2)

        ax.tick_params(axis="both", which="both", top=False, right=False)
        ax.set_xlim(0, 14)
        ax.set_ylim(y_bins[0], y_bins[-1])

        ticks = np.arange(vmin, vmax + COLOR_TICK_STEP, COLOR_TICK_STEP)

        cbar = fig.colorbar(
            mesh,
            cax=cax,
            orientation="vertical",
            extend="both",
            boundaries=ticks,
            ticks=ticks,
            spacing="proportional",
        )

        cbar.set_label(
            "Relative DOD Anomaly (%)\n(Anomaly vs. Climatology)",
            fontsize=15,
            rotation=90,
            labelpad=16,
        )
        cbar.ax.tick_params(labelsize=12, width=1.0, length=4)
        cbar.outline.set_linewidth(1.2)

        fig.text(
            0.00,
            0.93,
            "c",
            fontsize=35,
            fontweight="bold",
            ha="left",
            va="top",
        )

        fig.savefig(output_file, dpi=300, bbox_inches="tight")
        print(f"图片已保存到: {output_file}")

        plt.show()

    finally:
        ds_wind.close()
        ds_evi.close()
        ds1.close()
        ds2.close()


if __name__ == "__main__":
    main()