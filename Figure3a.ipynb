# -*- coding: utf-8 -*-

import numpy as np
import xarray as xr
import matplotlib.pyplot as plt
from pathlib import Path
from matplotlib import colors as mcolors
from mpl_toolkits.axes_grid1.inset_locator import inset_axes


SHAP_NC = (
    r"/mnt/l/FD_Data_Process/RF_Model/Result/RF/"
    r"RF_OOF_SHAP_Result_EVENT_RandomKFold_UNIFIED_WITH_XGB_INPUTS_NoWindMax_SoilNegToNaN/"
    r"shap_maps_rf_OOF.nc"
)

OUT_DIR = r"/mnt/l/FD_Data_Process/Figures/RF"

OUT_FIG_NAME = (
    "feature_importance_global_OOF_EVENT_RF_groupColored_sunburst_"
    "NoWindMax_SoilNegToNaN_Code2Output.png"
)

EXCLUDE_FEATURES = {
    "duration_steps",
    "cumulative_deficit_total",
}

FEATURE_GROUPS = {
    "Meteorology": [
        "wind_speed_5d_event_mean",
        "wind_speed_5d_event_max",
        "blh_5d_event_mean",
        "sshf_5d_event_mean",
        "tp_5d_event_mean",
    ],
    "HydroVeg": [
        "sms_5d_event_mean",
        "EVI_pentad_raw_event_mean",
        "snowc_5d_event_mean",
    ],
    "Background": [
        "AI",
        "CACO3",
        "Clay",
        "OC",
        "Sand",
    ],
}

FEATURE_ABBR = {
    "wind_speed_5d_event_mean": "WME",
    "wind_speed_5d_event_max": "WMA",
    "blh_5d_event_mean": "BLH",
    "sshf_5d_event_mean": "SSHF",
    "tp_5d_event_mean": "TP",
    "sms_5d_event_mean": "SMS",
    "EVI_pentad_raw_event_mean": "EVI",
    "snowc_5d_event_mean": "SC",
    "AI": "AI",
    "CACO3": "CaCO$_3$",
    "Clay": "Clay",
    "OC": "OC",
    "Sand": "Sand",
}

GROUP_AGG = "sum"

GROUP_COLORS = {
    "Meteorology": "#F1D27A",
    "HydroVeg": "#77C8B5",
    "Background": "#C9C9C9",
    "Other": "#B0B0B0",
}

TOPK_OUTER = 20
MIN_OUTER_PCT_LABEL = 3.0
SHOW_VALUE_LABELS = False
FORCE_SHOW_OUTER_LABELS = {"TP"}

DONUT_INNER_WIDTH = 0.46
DONUT_OUTER_WIDTH = 0.32

INNER_LABEL_MIN_PCT = 4.0
INNER_LABEL_ROT_MAP = {
    "Meteorology": 183,
    "HydroVeg": -5,
    "Background": 0,
    "Other": 0,
}

INNER_PCT_MIN = 4.0
INNER_PCT_FMT = "{:.1f}%"
INNER_PCT_FS = 8.8
INNER_PCT_COLOR = "black"
INNER_PCT_LINE_LW = 1.0

INNER_PCT_R_LINE_START = 1.0 - DONUT_INNER_WIDTH * 0.78
INNER_PCT_R_LINE_END = 1.0 - DONUT_INNER_WIDTH - 0.03
INNER_PCT_R_TEXT = 1.0 - DONUT_INNER_WIDTH - 0.22


def _decode_feature_names(ds: xr.Dataset):
    if "feature" not in ds.coords:
        raise KeyError(f"No coord 'feature' in dataset. coords={list(ds.coords)}")

    vals = ds.coords["feature"].values

    if len(vals) == 0:
        return []

    if isinstance(vals[0], (bytes, np.bytes_)):
        return [v.decode("utf-8") for v in vals]

    return [str(v) for v in vals]


def _abbr_name(name: str) -> str:
    return FEATURE_ABBR.get(name, name)


def _group_aggregate(feat_to_imp, feature_groups, agg="sum"):
    out = {}
    missing = {}

    for gname, feats in feature_groups.items():
        vals = []
        miss = []

        for f in feats:
            if f in feat_to_imp:
                vals.append(float(feat_to_imp[f]))
            else:
                miss.append(f)

        if vals:
            if agg == "sum":
                out[gname] = float(np.sum(vals))
            elif agg == "max":
                out[gname] = float(np.max(vals))
            else:
                out[gname] = float(np.mean(vals))

        if miss:
            missing[gname] = miss

    return out, missing


def _make_feat2group(feature_groups: dict):
    feat2group = {}

    for g, feats in feature_groups.items():
        for f in feats:
            feat2group[f] = g

    return feat2group


def _lighten(color, amount=0.35):
    c = np.array(mcolors.to_rgb(color))
    white = np.array([1.0, 1.0, 1.0])
    return tuple(c * (1 - amount) + white * amount)


def _draw_sunburst_donut(
    ax,
    features_raw,
    importances,
    feat2group,
    group_colors,
    inner_width=0.46,
    outer_width=0.32,
    startangle=90,
    min_outer_pct_label=3.0,
    show_outer_labels=True,
    force_show_outer_labels=None,
):
    features_raw = list(features_raw)
    importances = np.asarray(importances, dtype=np.float64)
    force_show_outer_labels = set() if force_show_outer_labels is None else set(force_show_outer_labels)

    total = float(np.sum(importances))

    if not np.isfinite(total) or total <= 0:
        ax.axis("off")
        return

    g2items = {}

    for f_raw, v in zip(features_raw, importances):
        g = feat2group.get(f_raw, "Other")
        g2items.setdefault(g, []).append((f_raw, float(v)))

    groups = []
    gvals = []

    for g, items in g2items.items():
        groups.append(g)
        gvals.append(sum(v for _, v in items))

    order_g = np.argsort(np.array(gvals))[::-1]
    groups = [groups[i] for i in order_g]
    gvals = [gvals[i] for i in order_g]

    outer_vals = []
    outer_labels = []
    outer_colors = []

    for g, _gv in zip(groups, gvals):
        items = sorted(g2items[g], key=lambda x: x[1], reverse=True)
        base_c = group_colors.get(g, group_colors.get("Other", "#B0B0B0"))

        for f_raw, v in items:
            outer_vals.append(v)
            outer_labels.append(_abbr_name(f_raw))
            outer_colors.append(_lighten(base_c, amount=0.35))

    inner_colors = [
        group_colors.get(g, group_colors.get("Other", "#B0B0B0"))
        for g in groups
    ]

    inner_wedges, _ = ax.pie(
        gvals,
        radius=1.0,
        labels=None,
        colors=inner_colors,
        startangle=startangle,
        counterclock=False,
        wedgeprops=dict(width=inner_width, edgecolor="white", linewidth=1.2),
    )

    for w, lab, v in zip(inner_wedges, groups, gvals):
        pct = 100.0 * v / total

        if pct < INNER_LABEL_MIN_PCT:
            continue

        ang = (w.theta1 + w.theta2) / 2.0
        ang_rad = np.deg2rad(ang)

        r_lab = 1.0 - inner_width / 2.0
        x_lab = r_lab * np.cos(ang_rad)
        y_lab = r_lab * np.sin(ang_rad)

        rot = ang - 90
        rot += INNER_LABEL_ROT_MAP.get(lab, 0)

        if rot < -90:
            rot += 180
        if rot > 90:
            rot -= 180

        ax.text(
            x_lab,
            y_lab,
            lab,
            ha="center",
            va="center",
            fontsize=8.8,
            rotation=rot,
            rotation_mode="anchor",
        )

        if pct >= INNER_PCT_MIN:
            x1 = INNER_PCT_R_LINE_START * np.cos(ang_rad)
            y1 = INNER_PCT_R_LINE_START * np.sin(ang_rad)
            x2 = INNER_PCT_R_LINE_END * np.cos(ang_rad)
            y2 = INNER_PCT_R_LINE_END * np.sin(ang_rad)
            xt = INNER_PCT_R_TEXT * np.cos(ang_rad)
            yt = INNER_PCT_R_TEXT * np.sin(ang_rad)

            ax.plot(
                [x1, x2],
                [y1, y2],
                color=INNER_PCT_COLOR,
                linewidth=INNER_PCT_LINE_LW,
                solid_capstyle="round",
            )

            ax.text(
                xt,
                yt,
                INNER_PCT_FMT.format(pct),
                ha="center",
                va="center",
                fontsize=INNER_PCT_FS,
                color=INNER_PCT_COLOR,
            )

    outer_radius = 1.0 + outer_width

    outer_wedges, _ = ax.pie(
        outer_vals,
        radius=outer_radius,
        labels=None,
        colors=outer_colors,
        startangle=startangle,
        counterclock=False,
        wedgeprops=dict(width=outer_width, edgecolor="white", linewidth=1.2),
    )

    if show_outer_labels:
        for w, lab, v in zip(outer_wedges, outer_labels, outer_vals):
            pct = 100.0 * v / total

            if pct < min_outer_pct_label and lab not in force_show_outer_labels:
                continue

            ang = (w.theta1 + w.theta2) / 2.0
            r = outer_radius - outer_width / 2.0
            x = r * np.cos(np.deg2rad(ang))
            y = r * np.sin(np.deg2rad(ang))

            rot = ang - 90

            if rot < -90:
                rot += 180
            if rot > 90:
                rot -= 180

            ax.text(
                x,
                y,
                lab,
                ha="center",
                va="center",
                fontsize=9,
                rotation=rot,
                rotation_mode="anchor",
            )

    ax.set_aspect("equal")
    ax.axis("off")


def _plot_reference_style_sunburst(
    out_dir: Path,
    sorted_features_raw: list,
    sorted_importance: np.ndarray,
    feat2group: dict,
    fname: str,
):
    N = len(sorted_features_raw)

    fig = plt.figure(figsize=(6, 8), dpi=150)

    gs = fig.add_gridspec(
        nrows=6,
        ncols=6,
        width_ratios=[1, 1, 1, 1, 1, 1],
        height_ratios=[1, 1, 1, 1, 1, 1],
        wspace=0.05,
        hspace=0.20,
    )

    ax_bar = fig.add_subplot(gs[:, :])

    ax_donut = inset_axes(
        ax_bar,
        width="48%",
        height="48%",
        loc="lower left",
        bbox_to_anchor=(0.48, 0.04, 1, 1),
        bbox_transform=ax_bar.transAxes,
        borderpad=0.0,
    )

    labs_raw = sorted_features_raw[::-1]
    labs = [_abbr_name(x) for x in labs_raw]
    vals = sorted_importance[::-1]
    y = np.arange(N)

    bar_colors = [
        GROUP_COLORS.get(feat2group.get(f_raw, "Other"), GROUP_COLORS["Other"])
        for f_raw in labs_raw
    ]

    ax_bar.barh(
        y,
        vals,
        height=0.72,
        color=bar_colors,
        edgecolor="none",
        alpha=0.92,
    )

    ax_bar.set_yticks(y)
    ax_bar.set_yticklabels(labs, fontsize=10)
    ax_bar.set_xlabel("Weighted Mean |SHAP| Value (by n_samples)", fontsize=11)

    ax_bar.spines["top"].set_visible(False)
    ax_bar.spines["right"].set_visible(False)
    ax_bar.grid(False)
    ax_bar.set_axisbelow(True)

    if SHOW_VALUE_LABELS:
        vmax = float(np.nanmax(vals)) if np.isfinite(vals).any() else 0.0
        offset = 0.012 * (vmax + 1e-12)

        for i, v in enumerate(vals):
            if np.isfinite(v):
                ax_bar.text(
                    v + offset,
                    i,
                    f"{v:.3f}",
                    va="center",
                    ha="left",
                    fontsize=8,
                    color="gray",
                )

    topk = min(TOPK_OUTER, len(sorted_features_raw))

    _draw_sunburst_donut(
        ax=ax_donut,
        features_raw=sorted_features_raw[:topk],
        importances=sorted_importance[:topk],
        feat2group=feat2group,
        group_colors=GROUP_COLORS,
        inner_width=DONUT_INNER_WIDTH,
        outer_width=DONUT_OUTER_WIDTH,
        startangle=90,
        min_outer_pct_label=MIN_OUTER_PCT_LABEL,
        show_outer_labels=True,
        force_show_outer_labels=FORCE_SHOW_OUTER_LABELS,
    )

    plt.tight_layout()

    out_path = out_dir / fname
    plt.savefig(out_path, dpi=300, bbox_inches="tight", facecolor="white")
    print(f"✅ Saved: {out_path}")

    plt.show()
    plt.close(fig)


def main():
    print("=" * 72)
    print("EVENT-LEVEL OOF SHAP Global Importance Plotter (RF SUNBURST)")
    print("=" * 72)

    shap_path = Path(SHAP_NC)

    if not shap_path.exists():
        raise FileNotFoundError(f"SHAP_NC not found: {shap_path}")

    out_dir = Path(OUT_DIR)
    out_dir.mkdir(parents=True, exist_ok=True)

    print(f"SHAP_NC  : {shap_path.resolve()}")
    print(f"OUT_DIR  : {out_dir.resolve()} (exists={out_dir.exists()})")
    print(f"OUT_FIG  : {OUT_FIG_NAME}")
    print(f"GROUP_AGG: {GROUP_AGG}")
    print(f"TOPK_OUTER={TOPK_OUTER} | MIN_OUTER_PCT_LABEL={MIN_OUTER_PCT_LABEL}")
    print(f"FORCE_SHOW_OUTER_LABELS: {sorted(FORCE_SHOW_OUTER_LABELS)}")
    print(f"EXCLUDE_FEATURES: {sorted(EXCLUDE_FEATURES)}")
    print("=" * 72)

    print("Loading OOF SHAP maps ...")

    ds = xr.open_dataset(shap_path)

    try:
        if "mean_abs_shap" not in ds:
            raise KeyError(f"Dataset lacks 'mean_abs_shap'. Available vars={list(ds.data_vars)}")
        if "n_samples" not in ds:
            raise KeyError(f"Dataset lacks 'n_samples'. Available vars={list(ds.data_vars)}")

        mean_abs_shap = ds["mean_abs_shap"]
        n_samples = ds["n_samples"]
        feature_names = _decode_feature_names(ds)

        print(f"Features in nc: {len(feature_names)}")
        print("Feature names from nc:")

        for f in feature_names:
            print("  -", f)

        print(
            f"mean_abs_shap shape: {tuple(mean_abs_shap.shape)} | "
            f"n_samples shape: {tuple(n_samples.shape)}"
        )

        weights = xr.where(np.isfinite(n_samples) & (n_samples > 0), n_samples, 0.0)
        w_sum = weights.sum()

        try:
            w_sum_val = float(w_sum.values)
        except Exception:
            w_sum_val = float(w_sum.compute().values)

        if not np.isfinite(w_sum_val) or w_sum_val <= 0:
            raise ValueError(
                "Sum of weights (n_samples>0) is zero/invalid. "
                "Check n_samples in the SHAP nc."
            )

        weights_norm = weights / w_sum
        global_importance = (mean_abs_shap * weights_norm).sum(dim=["lat", "lon"]).values
        global_importance = np.asarray(global_importance, dtype=np.float64)

        sorted_idx = np.argsort(global_importance)[::-1]
        sorted_features_raw_all = [feature_names[i] for i in sorted_idx]
        sorted_importance_all = global_importance[sorted_idx]

        filtered = [
            (f, v)
            for f, v in zip(sorted_features_raw_all, sorted_importance_all)
            if f not in EXCLUDE_FEATURES
        ]

        if len(filtered) == 0:
            raise ValueError(
                "After excluding features, no features remain for plotting. "
                f"EXCLUDE_FEATURES={sorted(EXCLUDE_FEATURES)}"
            )

        sorted_features_raw = [f for f, _ in filtered]
        sorted_importance = np.array([v for _, v in filtered], dtype=np.float64)

        print("\nExcluded features:")

        excluded_found = [f for f in sorted_features_raw_all if f in EXCLUDE_FEATURES]

        if excluded_found:
            for f in excluded_found:
                print(f"  - {f}")
        else:
            print("  (none found in nc)")

        print("\nGlobal Feature Importance Ranking (after exclusion):")

        for i, (feat, imp) in enumerate(zip(sorted_features_raw, sorted_importance), 1):
            print(f"  {i:02d}. {feat:35s} ({_abbr_name(feat):>9s}): {imp:.6f}")

        feat_to_imp = {
            f: float(v)
            for f, v in zip(sorted_features_raw, sorted_importance)
        }

        group_importance, missing = _group_aggregate(
            feat_to_imp,
            FEATURE_GROUPS,
            agg=GROUP_AGG,
        )

        if missing:
            print("\n⚠️ Some group features not found in filtered feature_names (ignored):")

            for g, miss in missing.items():
                short = miss[:20]
                more = "" if len(miss) <= 20 else f" ... (+{len(miss) - 20} more)"
                print(f"  - {g}: {short}{more}")

        print("\nGroup Importance Ranking:")

        if group_importance:
            for i, (g, imp) in enumerate(
                sorted(group_importance.items(), key=lambda x: x[1], reverse=True),
                1,
            ):
                print(f"  {i:02d}. {g:15s}: {imp:.6f}")
        else:
            print("  No group importance computed.")

        feat2group = _make_feat2group(FEATURE_GROUPS)

        _plot_reference_style_sunburst(
            out_dir=out_dir,
            sorted_features_raw=sorted_features_raw,
            sorted_importance=sorted_importance,
            feat2group=feat2group,
            fname=OUT_FIG_NAME,
        )

    finally:
        ds.close()

    print("\nDone.")


if __name__ == "__main__":
    main()