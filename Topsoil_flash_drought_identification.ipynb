#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import gc
import pickle
import warnings

import numba
import numpy as np
import pandas as pd
import psutil
import xarray as xr
from netCDF4 import Dataset
from tqdm import tqdm

warnings.filterwarnings("ignore")

PERCENT_NC = r"M:\Result\SoilMoisture\GLEAM\gleam.sms.pentad.percent.2003-2022.nc"
MASK_NC = r"M:\ERA5_land_sea_mask\ERA5_land_sea_mask.nc"

OUT_DIR = r"L:\FD_Data_Process"
os.makedirs(OUT_DIR, exist_ok=True)

OUT_STATS_NC = os.path.join(OUT_DIR, "FD_global_fortran_equiv.nc")
OUT_DRT_NC = os.path.join(OUT_DIR, "FD_drt_land_fortran_equiv.nc")
OUT_PKL = os.path.join(OUT_DIR, "FD_global_fortran_equiv_with_drt.pkl")

START_YEAR, END_YEAR = 2003, 2022
LAND_THRESHOLD = 0.5
TARGET_CHUNK_SIZE = 1000

KEEP_MAX_DURATION = True
MAX_DURATION_KEEP = 20

THRESH = 40.0
THRESH1 = 20.0
SPEED = 5.0
TD = 4


@numba.njit(cache=True, fastmath=False)
def flashdrought_fortran_equiv(
    a,
    thresh=40.0,
    thresh1=20.0,
    speed=5.0,
    td=4
):
    n = a.shape[0]
    drt = np.zeros(n, dtype=np.int8)
    events = []

    if n < 2:
        return drt, events

    cnt = 0
    flag = 0
    flag2 = 0
    tmin = 99.0
    si = 0

    odur = 0
    osev = 0.0
    ospd = 0.0
    last_active = -1
    last_onset = -1
    first20 = -1

    for i in range(n):
        if a[i] < 0.0:
            drt[:] = 0
            return drt, events

    for j in range(1, n):
        if a[j] < thresh:
            if flag == 0:
                flag1 = 1
                if j > 0 and a[j - 1] < thresh:
                    flag1 = 0

                if flag1 == 1:
                    flag = 1
                    flag2 = 1
                    cnt += 1

                    si = j
                    odur = 1
                    osev = thresh - a[j]
                    ospd = thresh - a[j]

                    tmin = a[j]
                    last_active = j
                    last_onset = j
                    first20 = j if a[j] <= thresh1 else -1

                    drt[j] = 1

            else:
                if flag2 == 1:
                    if thresh - a[j] >= (j - si + 1) * speed:
                        if tmin <= thresh1:
                            if a[j] >= a[j - 1]:
                                flag2 = 0
                                if a[j] <= thresh1:
                                    osev += thresh - a[j]
                                    odur += 1
                                    last_active = j

                                    if a[j] < tmin:
                                        tmin = a[j]
                                    if first20 == -1:
                                        first20 = j

                                    drt[j] = 2

                                else:
                                    flag = 0
                                    tmin = 99.0

                                    if odur < td:
                                        drt[si:j] = 0
                                        cnt -= 1
                                    else:
                                        endidx = last_active
                                        onsetdur = last_onset - si + 1
                                        events.append(
                                            (odur, osev, si, first20, endidx, ospd, onsetdur)
                                        )

                            else:
                                osev += thresh - a[j]
                                odur += 1
                                ospd = (thresh - a[j]) / (j - si + 1)

                                last_active = j
                                last_onset = j

                                if a[j] < tmin:
                                    tmin = a[j]
                                if first20 == -1 and a[j] <= thresh1:
                                    first20 = j

                                drt[j] = 1

                        else:
                            osev += thresh - a[j]
                            odur += 1
                            ospd = (thresh - a[j]) / (j - si + 1)

                            last_active = j
                            last_onset = j

                            if a[j] < tmin:
                                tmin = a[j]
                            if first20 == -1 and a[j] <= thresh1:
                                first20 = j

                            drt[j] = 1

                    else:
                        flag2 = 0

                        if tmin <= thresh1:
                            if a[j] <= thresh1:
                                osev += thresh - a[j]
                                odur += 1
                                last_active = j

                                if first20 == -1:
                                    first20 = j
                                if a[j] < tmin:
                                    tmin = a[j]

                                drt[j] = 2

                            else:
                                flag = 0
                                tmin = 99.0

                                if odur < td:
                                    drt[si:j] = 0
                                    cnt -= 1
                                else:
                                    endidx = last_active
                                    onsetdur = last_onset - si + 1
                                    events.append(
                                        (odur, osev, si, first20, endidx, ospd, onsetdur)
                                    )

                        else:
                            drt[si:j] = 0
                            cnt -= 1
                            flag = 0
                            tmin = 99.0

                else:
                    if a[j] <= thresh1:
                        osev += thresh - a[j]
                        odur += 1
                        last_active = j

                        if first20 == -1:
                            first20 = j
                        if a[j] < tmin:
                            tmin = a[j]

                        drt[j] = 2

                    else:
                        if odur < td:
                            drt[si:j] = 0
                            cnt -= 1
                        else:
                            endidx = last_active
                            onsetdur = last_onset - si + 1
                            events.append(
                                (odur, osev, si, first20, endidx, ospd, onsetdur)
                            )

                        flag = 0
                        tmin = 99.0

            if j == n - 1 and flag == 1:
                if odur < td or tmin > thresh1:
                    drt[si:j + 1] = 0
                    cnt -= 1
                else:
                    endidx = last_active
                    onsetdur = last_onset - si + 1
                    events.append(
                        (odur, osev, si, first20, endidx, ospd, onsetdur)
                    )

                flag = 0
                tmin = 99.0

        else:
            if flag == 1:
                if odur < td or tmin > thresh1:
                    drt[si:j + 1] = 0
                    cnt -= 1
                else:
                    endidx = last_active
                    onsetdur = last_onset - si + 1
                    events.append(
                        (odur, osev, si, first20, endidx, ospd, onsetdur)
                    )

                flag = 0
                tmin = 99.0

    return drt, events


def load_and_resample_land_mask(mask_path, target_lats, target_lons, land_threshold=0.5):
    print("🗺️ Loading and resampling land-sea mask...")

    with xr.open_dataset(mask_path) as ds_mask:
        if "lsm" in ds_mask.data_vars:
            lsm = ds_mask["lsm"]
        elif "land_sea_mask" in ds_mask.data_vars:
            lsm = ds_mask["land_sea_mask"]
        else:
            lsm = ds_mask[list(ds_mask.data_vars)[0]]

        if "time" in lsm.dims and lsm.sizes["time"] == 1:
            lsm = lsm.isel(time=0)

        mask_lats = lsm.latitude.values if "latitude" in lsm.dims else lsm.lat.values
        mask_lons = lsm.longitude.values if "longitude" in lsm.dims else lsm.lon.values
        mask_data = lsm.values

    if mask_lons.max() > 180:
        mask_lons = np.where(mask_lons > 180, mask_lons - 360, mask_lons)
        sidx = np.argsort(mask_lons)
        mask_lons = mask_lons[sidx]
        mask_data = mask_data[:, sidx]

    mask_ds = xr.Dataset(
        {"lsm": (["latitude", "longitude"], mask_data)},
        coords={"latitude": mask_lats, "longitude": mask_lons}
    )

    resampled = mask_ds.interp(
        latitude=target_lats,
        longitude=target_lons,
        method="nearest"
    )["lsm"].values

    land = np.where(resampled > land_threshold)
    land_points = list(zip(land[0], land[1]))

    print(f"✅ Land cells: {len(land_points)}")

    return resampled, land_points


def create_chunks(points, chunk_size):
    return [points[i:i + chunk_size] for i in range(0, len(points), chunk_size)]


def init_drt_land_netcdf(out_nc, time_vals, cell_lats, cell_lons, cell_lat_idx, cell_lon_idx):
    if os.path.exists(out_nc):
        os.remove(out_nc)

    ntime = len(time_vals)
    nc = Dataset(out_nc, "w", format="NETCDF4")

    nc.createDimension("time", ntime)
    nc.createDimension("cell", len(cell_lats))

    vtime = nc.createVariable("time", "f8", ("time",))
    vtime.units = "days since 1970-01-01 00:00:00"
    vtime.calendar = "proleptic_gregorian"

    epoch = np.datetime64("1970-01-01T00:00:00")
    t_np = np.array([np.datetime64(t) for t in time_vals])
    vtime[:] = ((t_np - epoch) / np.timedelta64(1, "D")).astype(np.float64)

    vlat = nc.createVariable("lat", "f4", ("cell",))
    vlon = nc.createVariable("lon", "f4", ("cell",))
    vli = nc.createVariable("lat_idx", "i4", ("cell",))
    vloi = nc.createVariable("lon_idx", "i4", ("cell",))

    vlat[:] = cell_lats.astype(np.float32)
    vlon[:] = cell_lons.astype(np.float32)
    vli[:] = cell_lat_idx.astype(np.int32)
    vloi[:] = cell_lon_idx.astype(np.int32)

    vdrt = nc.createVariable(
        "drt",
        "i1",
        ("time", "cell"),
        zlib=True,
        complevel=4,
        chunksizes=(min(200, ntime), min(512, len(cell_lats)))
    )

    vdrt.long_name = "Flash drought state (Fortran-equivalent): 0=no drought, 1=onset, 2=recovery"
    vdrt[:] = 0

    nc.title = "Flash drought drt(time,cell) (Fortran-equivalent)"
    nc.description = "drt output matches Fortran flashdrought() state machine exactly; land-only storage"
    nc.close()


def save_stats_map_netcdf(FD_global, lats, lons, start_year, end_year, out_nc):
    nlat, nlon = len(lats), len(lons)
    nyears = end_year - start_year + 1

    event_count = np.full((nlat, nlon), np.nan, dtype=np.float32)
    avg_duration = np.full((nlat, nlon), np.nan, dtype=np.float32)
    avg_severity = np.full((nlat, nlon), np.nan, dtype=np.float32)
    avg_speed = np.full((nlat, nlon), np.nan, dtype=np.float32)
    avg_onset_dur = np.full((nlat, nlon), np.nan, dtype=np.float32)
    events_per_year = np.full((nlat, nlon), np.nan, dtype=np.float32)
    total_duration = np.full((nlat, nlon), np.nan, dtype=np.float32)

    for cell in FD_global.values():
        i, j = cell["lat_idx"], cell["lon_idx"]
        df = cell["events"]

        if df is None or df.empty:
            event_count[i, j] = 0
            events_per_year[i, j] = 0
            total_duration[i, j] = 0
            continue

        event_count[i, j] = len(df)
        avg_duration[i, j] = df["Duration"].mean()
        avg_severity[i, j] = df["Severity"].mean()
        avg_speed[i, j] = df["Speed"].mean()
        avg_onset_dur[i, j] = df["OnsetDur"].mean()
        events_per_year[i, j] = len(df) / nyears
        total_duration[i, j] = df["Duration"].sum()

    ds = xr.Dataset(
        {
            "event_count": (["lat", "lon"], event_count),
            "avg_duration": (["lat", "lon"], avg_duration),
            "avg_severity": (["lat", "lon"], avg_severity),
            "avg_speed": (["lat", "lon"], avg_speed),
            "avg_onset_duration": (["lat", "lon"], avg_onset_dur),
            "events_per_year": (["lat", "lon"], events_per_year),
            "total_duration": (["lat", "lon"], total_duration),
        },
        coords={"lat": lats, "lon": lons}
    )

    ds["avg_severity"].attrs.update({
        "long_name": "Mean severity (Fortran osev = sum(40 - percentile))",
        "units": "percentile-pentad"
    })

    ds["avg_speed"].attrs.update({
        "long_name": "Mean onset speed (Fortran ospd)",
        "units": "percentile per pentad"
    })

    ds.attrs.update({
        "title": "Flash Drought Events (Fortran-equivalent)",
        "description": "Identified using Fortran flashdrought state-machine (thresh=40, thresh1=20, speed=5, td=4)",
        "time_period": f"{start_year}-{end_year}",
        "creation_time": pd.Timestamp.now().strftime("%Y-%m-%d %H:%M:%S")
    })

    encoding = {v: {"zlib": True, "complevel": 6} for v in ds.data_vars}
    ds.to_netcdf(out_nc, encoding=encoding)
    ds.close()

    print(f"✅ Saved stats NetCDF: {out_nc}")


def main():
    print("🚀 Flash Drought Detection (Fortran-equivalent) + drt(time) EXACT")
    print(f"PERCENT_NC: {PERCENT_NC}")
    print(f"MASK_NC   : {MASK_NC}")
    print(f"OUT_DIR   : {OUT_DIR}")

    with xr.open_dataset(PERCENT_NC) as ds_meta:
        lats = ds_meta["lat"].values
        lons = ds_meta["lon"].values
        time_vals = [pd.Timestamp(t).to_pydatetime() for t in ds_meta["time"].values]
        var = list(ds_meta.data_vars)[0]
        ntime = ds_meta.sizes["time"]
        print(f"Grid={len(lats)}x{len(lons)} | time={ntime} | var={var}")

    _, land_points = load_and_resample_land_mask(
        MASK_NC,
        lats,
        lons,
        LAND_THRESHOLD
    )

    ncell = len(land_points)

    cell_lat_idx = np.array([p[0] for p in land_points], dtype=np.int32)
    cell_lon_idx = np.array([p[1] for p in land_points], dtype=np.int32)
    cell_lats = lats[cell_lat_idx].astype(np.float32)
    cell_lons = lons[cell_lon_idx].astype(np.float32)

    cell_grid_keys = np.array(
        [
            f"lat_{int(la)}_lon_{int(lo)}"
            for la, lo in zip(cell_lat_idx, cell_lon_idx)
        ],
        dtype=object
    )

    print("🧾 Initializing land-only drt NetCDF...")

    init_drt_land_netcdf(
        OUT_DRT_NC,
        time_vals,
        cell_lats,
        cell_lons,
        cell_lat_idx,
        cell_lon_idx
    )

    chunks = create_chunks(list(range(ncell)), TARGET_CHUNK_SIZE)

    print(f"📦 Chunks={len(chunks)} | chunk_size={TARGET_CHUNK_SIZE}")

    FD_global = {}
    proc = psutil.Process()

    with xr.open_dataset(PERCENT_NC) as ds_in:
        da = ds_in[var]

        nc_out = Dataset(OUT_DRT_NC, "a")
        vdrt = nc_out.variables["drt"]

        with tqdm(total=len(chunks), desc="Processing chunks") as pbar:
            for ci, cell_ids in enumerate(chunks):
                lat_idx = cell_lat_idx[cell_ids].astype(np.int64)
                lon_idx = cell_lon_idx[cell_ids].astype(np.int64)

                lat_min = int(lat_idx.min())
                lat_max = int(lat_idx.max())
                lon_min = int(lon_idx.min())
                lon_max = int(lon_idx.max())

                data_chunk = da.isel(
                    lat=slice(lat_min, lat_max + 1),
                    lon=slice(lon_min, lon_max + 1)
                ).load().values

                rel_lat = lat_idx - lat_min
                rel_lon = lon_idx - lon_min

                n_block = len(cell_ids)
                drt_block = np.zeros((ntime, n_block), dtype=np.int8)

                for kk in range(n_block):
                    la_rel = int(rel_lat[kk])
                    lo_rel = int(rel_lon[kk])

                    series = data_chunk[:, la_rel, lo_rel]

                    if np.isnan(series).all() or series.shape[0] < 10:
                        continue

                    drt_series, events = flashdrought_fortran_equiv(
                        series,
                        THRESH,
                        THRESH1,
                        SPEED,
                        TD
                    )

                    drt_block[:, kk] = drt_series

                    k_abs = cell_ids[kk]
                    la_abs = int(cell_lat_idx[k_abs])
                    lo_abs = int(cell_lon_idx[k_abs])
                    grid_key = cell_grid_keys[k_abs]

                    cell_obj = FD_global.get(grid_key)

                    if cell_obj is None:
                        cell_obj = {
                            "lat_idx": la_abs,
                            "lon_idx": lo_abs,
                            "lat": float(cell_lats[k_abs]),
                            "lon": float(cell_lons[k_abs]),
                            "drt": drt_series.astype(np.int8),
                            "events": []
                        }
                        FD_global[grid_key] = cell_obj
                    else:
                        cell_obj["drt"] = drt_series.astype(np.int8)

                    if len(events) > 0:
                        evt_list = cell_obj["events"]

                        for dur, sev, si, first20, endidx, ospd, onsetdur in events:
                            dur = int(dur)

                            if dur < TD:
                                continue

                            if KEEP_MAX_DURATION and dur >= MAX_DURATION_KEEP:
                                continue

                            start_dd = time_vals[si] if 0 <= si < ntime else None
                            onset_dd = time_vals[first20] if 0 <= first20 < ntime else None
                            end_dd = time_vals[endidx] if 0 <= endidx < ntime else None

                            evt_list.append({
                                "Duration": dur,
                                "Severity": float(sev),
                                "Speed": float(ospd),
                                "OnsetDur": int(onsetdur),
                                "StartIdx": int(si),
                                "First20Idx": int(first20),
                                "EndIdx": int(endidx),
                                "StartDD": start_dd,
                                "OnsetDD": onset_dd,
                                "EndDD": end_dd
                            })

                vdrt[:, np.array(cell_ids, dtype=np.int32)] = drt_block

                del data_chunk, drt_block, lat_idx, lon_idx, rel_lat, rel_lon

                if ci % 3 == 0:
                    gc.collect()

                pbar.set_postfix({
                    "cells": len(FD_global),
                    "mem_gb": f"{proc.memory_info().rss / 1e9:.1f}"
                })

                pbar.update(1)

        nc_out.close()

    print("🧮 Converting event lists to DataFrame...")

    for cell in FD_global.values():
        cell["events"] = pd.DataFrame(cell["events"])

    total_events = 0

    for cell in FD_global.values():
        df = cell["events"]
        total_events += 0 if df is None else len(df)

    print(f"\n✅ DONE: cells={len(FD_global)} | total_events={total_events}")

    with open(OUT_PKL, "wb") as f:
        pickle.dump(FD_global, f)

    print(f"✅ Saved PKL (with drt per cell): {OUT_PKL}")

    save_stats_map_netcdf(
        FD_global,
        lats,
        lons,
        START_YEAR,
        END_YEAR,
        OUT_STATS_NC
    )

    print(f"✅ Saved land-only drt NetCDF: {OUT_DRT_NC}")
    print("🎉 All outputs saved.")


if __name__ == "__main__":
    main()