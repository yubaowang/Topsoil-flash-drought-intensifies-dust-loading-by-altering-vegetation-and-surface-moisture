import os
import numpy as np
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature
import xarray as xr
import matplotlib.patches as patches
from matplotlib.colors import LinearSegmentedColormap, Normalize

file_path = r"L:\FD_Data_Process\FD_DOD_Event\GLEAM\01_03\FD_DOD_event_statistics_2D_FORTRAN_EQUIV_FIXED_0p3deg.nc"

output_dir = r"L:\FD_Data_Process\Figures\闪旱伴随强沙尘事件"
output_file = os.path.join(
    output_dir,
    "Percentage_of_Flash_Drought_Events_with_DOD90_FORTRAN_EQUIV_FIXED_mask_total_events_ge10_gradient_colorbar_with_weighted_lat_profile.png"
)

LAT_SMOOTH_WINDOW = 5
USE_MANUAL_XLIM = True
XMIN = 0
XMAX = 30

vmin = 0
vmax = 60

ds = xr.open_dataset(file_path, engine="netcdf4")

data = ds["events_with_dod90_percent"]
events_with_dod90 = ds["events_with_dod90"]
total_events = ds["total_events"]

valid_mask = total_events >= 10

data = data.where(valid_mask)
events_with_dod90 = events_with_dod90.where(valid_mask)
total_events = total_events.where(valid_mask)

n_total_cells = total_events.size
n_valid_cells = int(np.sum(valid_mask.values))

print(
    f"\n有效格点（total_events >= 10）: {n_valid_cells:,} / {n_total_cells:,} "
    f"({n_valid_cells / n_total_cells * 100:.2f}%)"
)

global_events_with_dod90_sum = np.nansum(events_with_dod90.values)
global_total_events_sum = np.nansum(total_events.values)

if global_total_events_sum > 0:
    global_percentage = global_events_with_dod90_sum / global_total_events_sum * 100.0
else:
    global_percentage = np.nan

print("\n全球总体统计（不是格点简单平均）:")
print(f"  分子 sum(events_with_dod90) = {int(global_events_with_dod90_sum):,}")
print(f"  分母 sum(total_events)      = {int(global_total_events_sum):,}")

if np.isfinite(global_percentage):
    print(f"  Global percentage          = {global_percentage:.2f}%")
else:
    print("  Global percentage          = NaN (有效 total_events 求和为 0，无法计算)")

os.makedirs(output_dir, exist_ok=True)

plt.rcParams.update({
    "font.family": "Arial",
    "font.size": 20,
    "axes.linewidth": 0.8,
    "axes.labelsize": 20,
    "xtick.labelsize": 18,
    "ytick.labelsize": 18,
    "legend.fontsize": 18,
    "figure.dpi": 300,
})

data_values = data.values
data_valid = data_values[np.isfinite(data_values)]

if data_valid.size == 0:
    ds.close()
    raise ValueError("剔除 total_events < 10 后，没有可用于绘图的有效格点。")

actual_min = np.nanmin(data_valid)
actual_max = np.nanmax(data_valid)

print(f"\nevents_with_dod90_percent Range (masked): {actual_min:.2f} to {actual_max:.2f}")
print(f"Grid-cell Mean (masked): {np.mean(data_valid):.2f}, Median: {np.median(data_valid):.2f}")

colors_continuous = [
    "#fff7ec",
    "#fee8c8",
    "#fdd49e",
    "#fdbb84",
    "#fc8d59",
    "#ef6548",
    "#d7301f",
    "#b30000",
    "#7f0000",
    "#4d0000",
]

cmap = LinearSegmentedColormap.from_list(
    "nature_highcontrast_continuous",
    colors_continuous,
    N=256,
)

cmap.set_bad("white")
cmap.set_over("#001f3f")
cmap.set_under("#fffdf5")

norm = Normalize(vmin=vmin, vmax=vmax)

lat_dim = None
lon_dim = None

for name in ["lat", "latitude", "y"]:
    if name in data.dims:
        lat_dim = name
        break

for name in ["lon", "longitude", "x"]:
    if name in data.dims:
        lon_dim = name
        break

if lat_dim is None or lon_dim is None:
    ds.close()
    raise ValueError(f"无法识别经纬度维度，当前 dims = {data.dims}")

print(f"检测到维度：lat_dim = {lat_dim}, lon_dim = {lon_dim}")

lat_events_sum = events_with_dod90.sum(dim=lon_dim, skipna=True)
lat_total_sum = total_events.sum(dim=lon_dim, skipna=True)

with np.errstate(divide="ignore", invalid="ignore"):
    lat_percentage = xr.where(
        lat_total_sum > 0,
        lat_events_sum / lat_total_sum * 100.0,
        np.nan,
    )

if LAT_SMOOTH_WINDOW > 1:
    lat_percentage = lat_percentage.rolling(
        {lat_dim: LAT_SMOOTH_WINDOW},
        center=True,
        min_periods=1,
    ).mean()

lat_vals = lat_percentage[lat_dim].values
profile_vals = lat_percentage.values

fig = plt.figure(figsize=(13.5, 6.3), facecolor="white")

ax_main = fig.add_axes([0.05, 0.14, 0.67, 0.76], projection=ccrs.Robinson())
ax_main.set_facecolor("white")

ax_lat = fig.add_axes([0.68, 0.27, 0.12, 0.63])

ax_main.add_feature(
    cfeature.OCEAN,
    facecolor="white",
    edgecolor="none",
    zorder=0,
)

im = ax_main.pcolormesh(
    data[lon_dim],
    data[lat_dim],
    data.values,
    transform=ccrs.PlateCarree(),
    cmap=cmap,
    norm=norm,
    shading="auto",
    zorder=1,
)

ax_main.add_feature(cfeature.COASTLINE, linewidth=0.5, color="black", zorder=3)
ax_main.add_feature(cfeature.BORDERS, linewidth=0.3, color="gray", zorder=3)
ax_main.set_global()

gl = ax_main.gridlines(
    draw_labels=False,
    linewidth=0.3,
    color="gray",
    alpha=0.5,
    zorder=2,
)

gl.xlines = True
gl.ylines = True

cbar = plt.colorbar(
    im,
    ax=ax_main,
    orientation="horizontal",
    pad=0.03,
    shrink=0.72,
    aspect=30,
    extend="max",
    ticks=np.arange(0, 61, 5),
)

cbar.set_label(
    "Co-occurrence Rates between Flash Drought Events and Strong Dust (%)",
    fontsize=13,
    fontweight="normal",
)

cbar.ax.tick_params(labelsize=11)

ax_main.text(
    -0.05,
    0.98,
    "a",
    transform=ax_main.transAxes,
    fontsize=24,
    fontweight="bold",
    fontfamily="Arial",
    ha="left",
    va="top",
    zorder=1000,
)

ax_lat.plot(
    profile_vals,
    lat_vals,
    color="#b30000",
    linewidth=2.4,
)

ax_lat.axvline(0, color="gray", linestyle="--", linewidth=1.0, alpha=0.6)

if USE_MANUAL_XLIM:
    ax_lat.set_xlim(XMIN, XMAX)
else:
    xmax = np.nanmax(profile_vals)
    xmax = np.ceil(xmax / 5) * 5
    xmax = max(xmax, 5)
    ax_lat.set_xlim(0, xmax)

ax_lat.set_ylim(-60, 90)

yticks = np.arange(-60, 91, 15)
ax_lat.set_yticks(yticks)
ax_lat.set_yticklabels([
    f"{abs(int(y))}°S" if y < 0 else ("0°" if y == 0 else f"{int(y)}°N")
    for y in yticks
])

ax_lat.set_xlabel("Co-occurrence Rate (%)", fontsize=13)
ax_lat.set_ylabel("Latitude (deg)", fontsize=13, rotation=270, labelpad=18)
ax_lat.yaxis.set_label_position("right")
ax_lat.yaxis.tick_right()

ax_lat.spines["top"].set_visible(False)
ax_lat.spines["left"].set_visible(False)
ax_lat.spines["right"].set_linewidth(1.0)
ax_lat.spines["bottom"].set_linewidth(1.0)

ax_lat.tick_params(axis="both", labelsize=10, width=1.0, length=4)
ax_lat.grid(False)

pos = ax_main.get_position()

hist_left_offset = -0.002
hist_bottom_offset = 0.058
hist_width = 0.18
hist_height = 0.18

pad_left = 0.018
pad_right = 0.000
pad_bottom = 0.070
pad_top = 0.030

panel_left = pos.x0 + hist_left_offset - pad_left
panel_bottom = pos.y0 + hist_bottom_offset - pad_bottom
panel_width = hist_width + pad_left + pad_right
panel_height = hist_height + pad_bottom + pad_top

bg_rect = patches.Rectangle(
    (panel_left, panel_bottom),
    panel_width,
    panel_height,
    transform=fig.transFigure,
    facecolor="white",
    edgecolor="white",
    linewidth=1.2,
    zorder=999,
    alpha=1.0,
)

fig.patches.append(bg_rect)

ax_hist = fig.add_axes(
    [
        pos.x0 + hist_left_offset,
        pos.y0 + hist_bottom_offset,
        hist_width,
        hist_height,
    ],
    zorder=1000,
)

ax_hist.set_facecolor("white")
ax_hist.patch.set_alpha(1.0)

hist_data = data.values.flatten()
hist_data = hist_data[np.isfinite(hist_data)]

n_bins_hist = 30

counts, bins, patches_hist = ax_hist.hist(
    hist_data,
    bins=n_bins_hist,
    color="steelblue",
    alpha=0.7,
    edgecolor="black",
    linewidth=0.5,
)

for i, p in enumerate(patches_hist):
    bin_center = (bins[i] + bins[i + 1]) / 2
    p.set_facecolor(cmap(norm(bin_center)))
    p.set_alpha(0.8)

ax_hist.set_xlabel("Percentage (%)", fontsize=9)
ax_hist.set_ylabel("Frequency", fontsize=9)
ax_hist.set_title("Data Distribution", fontsize=10, fontweight="bold")
ax_hist.tick_params(labelsize=8)
ax_hist.grid(False)

ax_hist.ticklabel_format(style="scientific", axis="y", scilimits=(0, 0))
ax_hist.yaxis.get_offset_text().set_fontsize(7)

mean_val = np.mean(hist_data)
std_val = np.std(hist_data)
median_val = np.median(hist_data)
max_val = np.max(hist_data)
min_val = np.min(hist_data)

stats_text = (
    f"Mean: {mean_val:.1f}\n"
    f"Std: {std_val:.1f}\n"
    f"Median: {median_val:.1f}\n"
    f"Max: {max_val:.1f}\n"
    f"Min: {min_val:.1f}"
)

ax_hist.text(
    0.63,
    0.80,
    stats_text,
    transform=ax_hist.transAxes,
    fontsize=7.5,
    verticalalignment="top",
    bbox=dict(boxstyle="round", facecolor="wheat", alpha=0.8),
)

for spine in ax_hist.spines.values():
    spine.set_edgecolor("black")
    spine.set_linewidth(1.0)

valid_profile = np.isfinite(profile_vals)

print("\n纬向剖面统计（事件加权）:")
print(f"  有效纬线数 = {np.sum(valid_profile):,}")

if np.any(valid_profile):
    print(f"  剖面最小值 = {np.nanmin(profile_vals):.2f}%")
    print(f"  剖面最大值 = {np.nanmax(profile_vals):.2f}%")

plt.savefig(
    output_file,
    dpi=300,
    bbox_inches="tight",
    facecolor="white",
    edgecolor="none",
)

plt.show()
ds.close()

print(f"\n图件已保存至:\n{output_file}")