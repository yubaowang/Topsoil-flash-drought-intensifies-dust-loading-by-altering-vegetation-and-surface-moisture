#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import numpy as np
import matplotlib.pyplot as plt


INPUT_DIR = r"L:\FD_Data_Process\Figures\EVI_WindPercent_EventLevel_DODThreshold_ULTRAFAST"
SUFFIX = "DODge90_eventlevel_completeWind"

INPUT_NPZ = os.path.join(INPUT_DIR, f"binned_result_{SUFFIX}.npz")

OUTPUT_DIR = r"L:\FD_Data_Process\Figures\闪旱伴随强沙尘事件"
os.makedirs(OUTPUT_DIR, exist_ok=True)

OUTPUT_PNG = os.path.join(OUTPUT_DIR, f"nature_redraw_{SUFFIX}_windX_eviY_countge100.png")
OUTPUT_PDF = os.path.join(OUTPUT_DIR, f"nature_redraw_{SUFFIX}_windX_eviY_countge100.pdf")

DOD_THRESHOLD = 90.0
ONSET_ONLY = False
MIN_COUNT = 100

FIG_W = 15
FIG_H = 6
DPI = 400

AUTO_PROB_RANGE = False
PROB_VMIN = 5
PROB_VMAX = 30

COUNT_VMIN = None
COUNT_VMAX = None

PROB_CMAP = "RdYlBu_r"
COUNT_CMAP = "viridis"

X_LABEL = "Event-Mean Wind Percentile (%)" if not ONSET_ONLY else "Onset-mean wind percentile"
Y_LABEL = "Event-Mean EVI Percentile (%)"

CBAR1_LABEL = "Probability (%)"
CBAR2_LABEL = "Flash Drought Count per Bin"

SHOW_FIG = True
SAVE_FIG = True


def format_panel(ax, xlabel, ylabel):
    ax.set_xlabel(xlabel, labelpad=6)
    ax.set_ylabel(ylabel, labelpad=6)
    ax.set_xlim(0, 100)
    ax.set_ylim(0, 100)
    ax.set_xticks(np.arange(0, 101, 20))
    ax.set_yticks(np.arange(0, 101, 20))

    for side in ["left", "right", "top", "bottom"]:
        ax.spines[side].set_visible(True)
        ax.spines[side].set_linewidth(0.9)

    ax.tick_params(
        axis="both",
        which="major",
        top=False,
        right=False,
        direction="out",
        length=4.5,
        width=0.9,
        pad=3
    )


def load_binned_npz(npz_file):
    data = np.load(npz_file)
    return {
        "x_bins": data["x_bins"],
        "y_bins": data["y_bins"],
        "z_mean": data["z_mean"],
        "counts": data["counts"].astype(np.int32),
        "n_total": int(data["n_total"][0]),
        "n_pos": int(data["n_pos"][0]),
        "n_neg": int(data["n_neg"][0]),
        "n_events": int(data["n_events"][0]),
    }


def apply_nature_style():
    plt.rcParams.update({
        "font.family": "Arial",
        "font.size": 10,
        "axes.labelsize": 14,
        "axes.titlesize": 12.5,
        "axes.linewidth": 0.9,
        "xtick.labelsize": 12,
        "ytick.labelsize": 12,
        "xtick.direction": "out",
        "ytick.direction": "out",
        "xtick.major.size": 4.5,
        "ytick.major.size": 4.5,
        "xtick.major.width": 0.9,
        "ytick.major.width": 0.9,
        "legend.fontsize": 10,
        "figure.facecolor": "white",
        "axes.facecolor": "white",
        "savefig.facecolor": "white",
        "savefig.bbox": "tight",
        "pdf.fonttype": 42,
        "ps.fonttype": 42,
    })


def get_range(arr, vmin, vmax):
    return (
        float(np.nanmin(arr)) if vmin is None else vmin,
        float(np.nanmax(arr)) if vmax is None else vmax
    )


def plot_from_binned_result(plot_data):
    evi_bins = plot_data["x_bins"]
    wind_bins = plot_data["y_bins"]

    z_mean_raw = plot_data["z_mean"].T
    counts = plot_data["counts"].T

    valid_mask = counts >= MIN_COUNT
    z_mean = np.where(valid_mask, z_mean_raw, np.nan)

    count_plot = counts.astype(np.float64)
    count_plot[~valid_mask] = np.nan

    n_valid_bins = int(np.sum(np.isfinite(z_mean)))
    n_total_bins = int(z_mean.size)

    if n_valid_bins == 0:
        raise ValueError(f"没有样本数 >= {MIN_COUNT} 的有效箱体可绘制。")

    print(f"仅保留样本数 >= {MIN_COUNT} 的箱体")
    print(f"有效箱体数: {n_valid_bins:,}")
    print(f"总箱体数: {n_total_bins:,}")
    print(f"分箱后事件概率范围: [{np.nanmin(z_mean):.4f}, {np.nanmax(z_mean):.4f}] %")
    print(f"分箱后样本数范围: [{np.nanmin(count_plot):.0f}, {np.nanmax(count_plot):.0f}]")

    if AUTO_PROB_RANGE:
        prob_vmin, prob_vmax = float(np.nanmin(z_mean)), float(np.nanmax(z_mean))
    else:
        prob_vmin, prob_vmax = PROB_VMIN, PROB_VMAX

    count_vmin, count_vmax = get_range(count_plot, COUNT_VMIN, COUNT_VMAX)

    apply_nature_style()

    prob_cmap = plt.get_cmap(PROB_CMAP).copy()
    prob_cmap.set_bad(color="white")

    count_cmap = plt.get_cmap(COUNT_CMAP).copy()
    count_cmap.set_bad(color="white")

    fig = plt.figure(figsize=(FIG_W, FIG_H), dpi=DPI)
    gs = fig.add_gridspec(
        1, 2,
        width_ratios=[1, 1],
        left=0.075,
        right=0.955,
        bottom=0.12,
        top=0.92,
        wspace=0.15
    )

    ax1 = fig.add_subplot(gs[0, 0])
    mesh1 = ax1.pcolormesh(
        wind_bins,
        evi_bins,
        z_mean,
        cmap=prob_cmap,
        shading="flat",
        rasterized=True,
        vmin=prob_vmin,
        vmax=prob_vmax
    )
    cb1 = fig.colorbar(mesh1, ax=ax1, pad=0.02, shrink=0.94, extend="both")
    cb1.set_label(CBAR1_LABEL, fontsize=11, labelpad=7)
    cb1.ax.tick_params(labelsize=11, width=0.8, length=3.5)
    cb1.outline.set_linewidth(0.8)
    format_panel(ax1, X_LABEL, Y_LABEL)

    ax2 = fig.add_subplot(gs[0, 1])
    mesh2 = ax2.pcolormesh(
        wind_bins,
        evi_bins,
        count_plot,
        cmap=count_cmap,
        shading="flat",
        rasterized=True,
        vmin=count_vmin,
        vmax=count_vmax
    )
    cb2 = fig.colorbar(mesh2, ax=ax2, pad=0.02, shrink=0.94, extend="both")
    cb2.set_label(CBAR2_LABEL, fontsize=11, labelpad=7)
    cb2.ax.tick_params(labelsize=11, width=0.8, length=3.5)
    cb2.outline.set_linewidth(0.8)
    format_panel(ax2, X_LABEL, Y_LABEL)

    if SAVE_FIG:
        plt.savefig(OUTPUT_PNG, dpi=DPI)
        plt.savefig(OUTPUT_PDF, dpi=DPI)
        print(f"✓ 图已保存: {OUTPUT_PNG}")
        print(f"✓ 图已保存: {OUTPUT_PDF}")

    if SHOW_FIG:
        plt.show()

    plt.close(fig)


def main():
    plot_data = load_binned_npz(INPUT_NPZ)
    plot_from_binned_result(plot_data)
    print("重绘完成。")


if __name__ == "__main__":
    main()