import os
import gc
import time
import warnings
import numpy as np
import xarray as xr
import psutil
import numba as nb
from tqdm import tqdm

warnings.filterwarnings("ignore")

data_base_path = "M:/GLEAM/data/v4.2a/daily"
output_path = "M:/Result/SoilMoisture/GLEAM"
mask_path = "M:/ERA5_land_sea_mask/ERA5_land_sea_mask.nc"

start_year, end_year = 2003, 2022
years = list(range(start_year, end_year + 1))

STANDARD_PENTADS_PER_YEAR = 73
WINDOW_SIZE = 3

READ_CHUNK_SIZE = {"time": 30, "lat": 240, "lon": 240}
NC_COMP = 4

PERCENTILE_MEM_FRAC = 0.22
PERCENTILE_CHUNK_MIN = 4000
PERCENTILE_CHUNK_MAX = 100000

os.makedirs(output_path, exist_ok=True)
os.chdir(output_path)


@nb.njit(cache=True)
def _rank_one_column(col_vals, n_rows):
    ranks = np.empty(n_rows, dtype=np.float32)

    buf_val = np.empty(n_rows, dtype=np.float64)
    buf_idx = np.empty(n_rows, dtype=np.int64)
    count = 0

    for i in range(n_rows):
        v = col_vals[i]
        if np.isnan(v):
            ranks[i] = np.nan
        else:
            buf_val[count] = v
            buf_idx[count] = i
            count += 1

    if count == 0:
        return ranks

    order = np.argsort(buf_val[:count])

    i = 0
    while i < count:
        j = i + 1
        while j < count and buf_val[order[j]] == buf_val[order[i]]:
            j += 1

        avg_rank = np.float32((i + 1 + j) * 0.5)

        for k in range(i, j):
            ranks[buf_idx[order[k]]] = avg_rank

        i = j

    return ranks


@nb.njit(parallel=True, cache=True)
def rank_columns_average_nan(mat, out):
    n_rows, n_cols = mat.shape

    for col in nb.prange(n_cols):
        col_data = mat[:, col]
        r = _rank_one_column(col_data, n_rows)

        for row in range(n_rows):
            out[row, col] = r[row]


@nb.njit(cache=True)
def count_valid_per_column(mat):
    n_rows, n_cols = mat.shape
    counts = np.zeros(n_cols, dtype=np.float32)

    for col in range(n_cols):
        c = np.float32(0.0)

        for row in range(n_rows):
            if not np.isnan(mat[row, col]):
                c += 1.0

        counts[col] = c

    return counts


def verify_coordinate_fix():
    print("🔍 验证坐标修复...")

    first_year_file = f"{data_base_path}/SMs_{start_year}_GLEAM_v4.2a.nc"

    if not os.path.exists(first_year_file):
        print("❌ 无法找到GLEAM数据文件进行验证")
        return False

    with xr.open_dataset(first_year_file, engine="netcdf4") as ds_data:
        gleam_lons = ds_data.lon.values

    with xr.open_dataset(mask_path, engine="netcdf4") as ds_mask:
        mask_lons = ds_mask.longitude.values
        mask_lons_converted = np.where(mask_lons > 180, mask_lons - 360, mask_lons)
        mask_lons_sorted = np.sort(mask_lons_converted)

        print(f"GLEAM经度范围: [{gleam_lons.min():.2f}, {gleam_lons.max():.2f}]")
        print(f"ERA5原始经度范围: [{mask_lons.min():.2f}, {mask_lons.max():.2f}]")
        print(f"ERA5转换后经度范围: [{mask_lons_sorted.min():.2f}, {mask_lons_sorted.max():.2f}]")

        gleam_west = np.sum(gleam_lons < 0)
        mask_west = np.sum(mask_lons_sorted < 0)

        print(f"GLEAM西半球经度点数: {gleam_west}")
        print(f"ERA5转换后西半球经度点数: {mask_west}")

        if gleam_west > 0 and mask_west > 0:
            print("✅ 坐标修复验证成功！")
            return True

        print("❌ 坐标修复验证失败！")
        return False


def open_one_year_dataset(year):
    fp = f"{data_base_path}/SMs_{year}_GLEAM_v4.2a.nc"

    if not os.path.exists(fp):
        raise FileNotFoundError(f"❌ 缺少文件: {fp}")

    ds = xr.open_dataset(fp, engine="netcdf4", chunks=READ_CHUNK_SIZE)

    if "SMs" not in ds.data_vars:
        ds.close()
        raise KeyError(f"数据文件中未找到变量 SMs: {fp}")

    return ds


def get_reference_coords():
    with open_one_year_dataset(start_year) as ds:
        lat = ds["lat"].copy()
        lon = ds["lon"].copy()

    return lat, lon


def prepare_land_mask(target_lat, target_lon):
    if not os.path.exists(mask_path):
        print("⚠️ 未找到掩膜文件，将不使用陆地掩膜")
        return None

    print("🗺️ 读取并对齐陆地掩膜...")

    with xr.open_dataset(mask_path, engine="netcdf4") as ds_mask:
        mask_vars = ["lsm", "land_sea_mask", "mask"]
        mask_var = next((v for v in mask_vars if v in ds_mask.data_vars), None)

        if mask_var is None:
            print("⚠️ 未找到掩膜变量")
            return None

        land_mask = ds_mask[mask_var]

        if "time" in land_mask.dims and land_mask.sizes["time"] == 1:
            land_mask = land_mask.isel(time=0)

        lat_name = "latitude" if "latitude" in land_mask.dims else "lat"
        lon_name = "longitude" if "longitude" in land_mask.dims else "lon"

        land_mask = land_mask.rename({lat_name: "lat", lon_name: "lon"})

        mask_lons = land_mask["lon"].values

        if np.nanmax(mask_lons) > 180:
            new_lons = np.where(mask_lons > 180, mask_lons - 360, mask_lons)
            sort_idx = np.argsort(new_lons)
            land_mask = land_mask.isel(lon=sort_idx)
            land_mask = land_mask.assign_coords(lon=new_lons[sort_idx])

        if not (
            np.array_equal(land_mask["lat"].values, target_lat.values)
            and np.array_equal(land_mask["lon"].values, target_lon.values)
        ):
            print("📐 掩膜与GLEAM网格不一致，执行最近邻重采样...")
            land_mask = land_mask.interp(lat=target_lat, lon=target_lon, method="nearest")

        return land_mask.values > 0.5


def _read_one_year_daily_values(year, land_mask, ref_lat, ref_lon):
    with open_one_year_dataset(year) as ds:
        if not (
            np.array_equal(ds["lat"].values, ref_lat.values)
            and np.array_equal(ds["lon"].values, ref_lon.values)
        ):
            raise ValueError(f"❌ {year} 年数据网格与参考网格不一致")

        da = ds["SMs"].where(ds["SMs"] != -999.0, np.nan).astype(np.float32)
        time_vals = ds["time"].values
        daily_vals = da.load().values.astype(np.float32, copy=False)

    if land_mask is not None:
        daily_vals = np.where(land_mask[None, :, :], daily_vals, np.nan)

    return daily_vals, time_vals


def build_pentad_from_daily_stream():
    print("📦 计算五日平均（逐年独立分组）...")

    year_len = end_year - start_year + 1
    standard_total_pentads = STANDARD_PENTADS_PER_YEAR * year_len

    lat, lon = get_reference_coords()
    land_mask = prepare_land_mask(lat, lon)

    nlat, nlon = lat.size, lon.size

    pentad_vals = np.full(
        (standard_total_pentads, nlat, nlon),
        np.nan,
        dtype=np.float32
    )
    pentad_dates = np.empty(standard_total_pentads, dtype="datetime64[ns]")

    print(f"标准 pentad 数: {standard_total_pentads} ({STANDARD_PENTADS_PER_YEAR}/年 × {year_len}年)")

    pentad_idx = 0
    total_days_seen = 0
    total_days_used = 0
    total_days_discarded = 0

    for y in years:
        print(f"\n📂 读取年份: {y}")

        daily_vals, time_vals = _read_one_year_daily_values(y, land_mask, lat, lon)
        n_days_this_year = daily_vals.shape[0]

        total_days_seen += n_days_this_year

        print(f"   年内天数: {n_days_this_year}")

        n_days_use = STANDARD_PENTADS_PER_YEAR * 5
        n_discard = n_days_this_year - n_days_use

        if n_days_this_year < n_days_use:
            raise ValueError(
                f"❌ {y} 年日数据不足: 需要 {n_days_use} 天，实际 {n_days_this_year} 天"
            )

        if n_discard > 0:
            print(f"   ℹ️ 闰年丢弃末尾 {n_discard} 天（第 {n_days_use + 1}~{n_days_this_year} 天）")

        for p in range(STANDARD_PENTADS_PER_YEAR):
            d0 = p * 5
            d1 = d0 + 5
            pentad_vals[pentad_idx] = np.nanmean(
                daily_vals[d0:d1],
                axis=0,
                dtype=np.float32
            )
            pentad_dates[pentad_idx] = time_vals[d0]
            pentad_idx += 1

        total_days_used += n_days_use
        total_days_discarded += n_discard

        del daily_vals, time_vals
        gc.collect()

    print(f"\n原始总天数: {total_days_seen}")
    print(f"实际使用天数: {total_days_used}")
    print(f"丢弃天数（闰年末尾）: {total_days_discarded}")
    print(f"实际生成 pentad 数: {pentad_idx}")

    if pentad_idx != standard_total_pentads:
        raise ValueError(f"pentad 数不一致：预期 {standard_total_pentads}，实际 {pentad_idx}")

    return pentad_vals, pentad_dates, lat, lon


def _process_one_chunk(chunk_data, year_len, pentads_per_year, window_size):
    total_pentads, n_pixels = chunk_data.shape

    chunk_y_p_n = chunk_data.reshape(year_len, pentads_per_year, n_pixels)
    out = np.full((year_len, pentads_per_year, n_pixels), np.nan, dtype=np.float32)

    win_len = 2 * window_size + 1
    center_block = window_size

    ranks_buf = np.empty((win_len * year_len, n_pixels), dtype=np.float32)

    all_window_pentads = [
        [
            (p + off) % pentads_per_year
            for off in range(-window_size, window_size + 1)
        ]
        for p in range(pentads_per_year)
    ]

    for p in range(pentads_per_year):
        window_pentads = all_window_pentads[p]

        window_mat = (
            chunk_y_p_n[:, window_pentads, :]
            .transpose(1, 0, 2)
            .reshape(win_len * year_len, n_pixels)
        )

        ranks_buf[:] = np.nan

        rank_columns_average_nan(window_mat, ranks_buf)

        row_start = center_block * year_len
        row_end = row_start + year_len

        current_ranks = ranks_buf[row_start:row_end, :]
        valid_counts = count_valid_per_column(window_mat)
        denom = valid_counts[np.newaxis, :] + 1.0

        out[:, p, :] = current_ranks / denom * 100.0

    return out.reshape(total_pentads, n_pixels)


def compute_percentiles_from_pentads(pentad_vals):
    print(f"📊 计算百分位数（±{WINDOW_SIZE} pentad 滑动窗口 | 单进程 Numba）...")

    year_len = end_year - start_year + 1

    first_pentad = pentad_vals[0]
    valid_mask = ~np.isnan(first_pentad)
    valid_indices = np.where(valid_mask)
    n_valid = len(valid_indices[0])

    print(f"有效像元数: {n_valid}")

    print("⚡ Numba JIT 编译预热...")

    _dummy = np.random.rand(14, 10).astype(np.float32)
    _dummy[0, 0] = np.nan
    _out = np.empty_like(_dummy)

    rank_columns_average_nan(_dummy, _out)
    count_valid_per_column(_dummy)

    print("⚡ JIT 编译完成")

    percentile_data = np.full_like(pentad_vals, np.nan, dtype=np.float32)

    available_gb = psutil.virtual_memory().available / (1024 ** 3)
    mem_budget = max(1.0, available_gb * PERCENTILE_MEM_FRAC) * (1024 ** 3)

    approx_bytes_per_pixel = pentad_vals.shape[0] * (4 + 4 + 12)
    chunk_size = int(mem_budget // approx_bytes_per_pixel)
    chunk_size = max(PERCENTILE_CHUNK_MIN, min(PERCENTILE_CHUNK_MAX, chunk_size))

    n_chunks = (n_valid + chunk_size - 1) // chunk_size

    print(f"chunk_size = {chunk_size}, 总 chunks = {n_chunks}")

    for ci in tqdm(range(n_chunks), desc="百分位数计算"):
        s = ci * chunk_size
        e = min(s + chunk_size, n_valid)

        ii = valid_indices[0][s:e]
        jj = valid_indices[1][s:e]

        chunk_data = pentad_vals[:, ii, jj]

        res = _process_one_chunk(
            chunk_data=chunk_data,
            year_len=year_len,
            pentads_per_year=STANDARD_PENTADS_PER_YEAR,
            window_size=WINDOW_SIZE
        )

        percentile_data[:, ii, jj] = res

        del chunk_data, res

        if (ci + 1) % 4 == 0:
            gc.collect()

    return percentile_data


def save_results(pentad_vals, percentile_data, pentad_dates, lat, lon):
    print("💾 保存结果...")

    coords = {
        "time": pentad_dates,
        "lat": lat.values,
        "lon": lon.values
    }

    encoding = {
        "zlib": True,
        "complevel": NC_COMP,
        "dtype": "float32",
        "chunksizes": (
            min(100, len(pentad_dates)),
            min(200, len(lat)),
            min(300, len(lon))
        ),
        "shuffle": True
    }

    save_name = f"gleam.sms.pentad.{start_year}-{end_year}.nc"

    ds_pentad = xr.Dataset(
        {
            "sms_5d": (
                ["time", "lat", "lon"],
                pentad_vals.astype(np.float32, copy=False)
            )
        },
        coords=coords
    )

    ds_pentad["sms_5d"].attrs = {
        "units": "m3.m-3",
        "long_name": "5-day mean surface soil moisture from GLEAM"
    }

    ds_pentad.to_netcdf(
        save_name,
        engine="netcdf4",
        encoding={"sms_5d": encoding}
    )

    ds_pentad.close()

    pct_name = f"gleam.sms.pentad.percent.{start_year}-{end_year}.nc"

    ds_pct = xr.Dataset(
        {
            "sms_5d_percent": (
                ["time", "lat", "lon"],
                percentile_data.astype(np.float32, copy=False)
            )
        },
        coords=coords
    )

    ds_pct["sms_5d_percent"].attrs = {
        "units": "percent",
        "long_name": "5-day mean surface soil moisture percentile from GLEAM",
        "method": f"Windowed percentile ±{WINDOW_SIZE} pentads, all years ({start_year}-{end_year})"
    }

    ds_pct.to_netcdf(
        pct_name,
        engine="netcdf4",
        encoding={"sms_5d_percent": encoding}
    )

    ds_pct.close()

    print(f"✅ 五日平均: {save_name} ({os.path.getsize(save_name) / 1e6:.1f} MB)")
    print(f"✅ 百分位数: {pct_name} ({os.path.getsize(pct_name) / 1e6:.1f} MB)")

    return save_name, pct_name


def main():
    print("🚀 GLEAM 土壤湿度处理器 V4（Numba 单进程稳定最终版）")
    print("📝 pentad 分组: 逐年独立（与 DOD/EVI 一致）")
    print(f"📊 处理范围: {start_year}-{end_year}")
    print(f"🪟 百分位方法: ±{WINDOW_SIZE} pentad 滑动窗口")
    print(f"📂 输入: {data_base_path}")
    print(f"📂 输出: {output_path}")

    t0 = time.time()

    try:
        print("\n🔍 步骤1: 验证坐标")
        verify_coordinate_fix()

        print("\n📦 步骤2: 逐年独立分组构建五日平均")
        pentad_vals, pentad_dates, lat, lon = build_pentad_from_daily_stream()

        print("\n📊 步骤3: 单进程 Numba 百分位计算")
        percentile_data = compute_percentiles_from_pentads(pentad_vals)

        print("\n💾 步骤4: 保存结果")
        save_results(pentad_vals, percentile_data, pentad_dates, lat, lon)

        elapsed = time.time() - t0

        print(f"\n🎉 完成！总耗时: {elapsed / 60:.2f} 分钟")

    except Exception as e:
        print(f"❌ 异常: {e}")

        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    main()