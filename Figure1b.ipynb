import numpy as np
import xarray as xr
import matplotlib.pyplot as plt
from scipy import stats
import warnings

warnings.filterwarnings("ignore")


def detect_lat_lon_names(dataset):
    lat_names = ["latitude", "lat", "y"]
    lon_names = ["longitude", "lon", "x"]

    lat_name = next(
        (name for name in lat_names if name in dataset.dims or name in dataset.coords),
        None,
    )
    lon_name = next(
        (name for name in lon_names if name in dataset.dims or name in dataset.coords),
        None,
    )

    if lat_name is None or lon_name is None:
        raise ValueError(
            f"无法检测到纬度/经度维度。\n"
            f"可用维度: {list(dataset.dims.keys())}\n"
            f"可用坐标: {list(dataset.coords.keys())}"
        )

    return lat_name, lon_name


FONT_FAMILY = "Arial"

FS_BASE = 12
FS_XTICK = 18
FS_YTICK = 18
FS_AXIS_LABEL = 20
FS_MEDIAN_TEXT = 12
FS_SAMPLE_N = 20
FS_SIGNIFICANCE = 20
FS_PANEL = 32
FS_PRINT_TABLE = 12

FIG_WIDTH = 10
FIG_HEIGHT = 6

AXES_LINEWIDTH = 1.5
TICK_WIDTH = 1.5
TICK_LENGTH = 5
VIOLIN_WIDTH = 0.75
BOXPLOT_WIDTH = 0.3

print("📂 加载数据...")

file_target = r"L:\FD_Data_Process\FD_DOD_Filtered_05Std_Filtered\Average\dod_event_multiyear_mean_from_v5p2_FINAL_filtered.nc"
file_climatology = r"L:\FD_Data_Process\FD_HighWind_DOD\Average\dod_event_multiyear_mean_with_climatology.nc"
landcover_path = r"M:\MODIS_LandCover\MCD12C1_6Types\MODIS_6Type_LandCover_2003_2022_Average_0.3deg.nc"

ds_target = xr.open_dataset(file_target)
ds_clim = xr.open_dataset(file_climatology)
ds_lc = xr.open_dataset(landcover_path)

lat_name_target, lon_name_target = detect_lat_lon_names(ds_target)
lat_name_clim, lon_name_clim = detect_lat_lon_names(ds_clim)
lat_name_lc, lon_name_lc = detect_lat_lon_names(ds_lc)

print(f"   ✓ 目标数据维度: {lat_name_target}, {lon_name_target}")
print(f"   ✓ 气候态数据维度: {lat_name_clim}, {lon_name_clim}")
print(f"   ✓ 土地覆盖数据维度: {lat_name_lc}, {lon_name_lc}")

data_target = ds_target["complete_dod_mean_mean"]
data_climatology = ds_clim["complete_dod_mean_climatology_mean"]
dominant_lc_da = ds_lc["dominant_land_cover"]

print(f"   目标数据 shape: {data_target.shape}")
print(f"   气候态数据 shape: {data_climatology.shape}")
print(f"   土地覆盖 shape: {dominant_lc_da.shape}")

print("\n🔍 对齐目标数据与气候态数据网格...")

if data_target.shape != data_climatology.shape:
    print("   ⚠️ 气候态数据与目标数据形状不同，进行插值...")
    data_climatology = data_climatology.interp(
        **{
            lat_name_clim: data_target[lat_name_target],
            lon_name_clim: data_target[lon_name_target],
        },
        method="nearest",
    )
    print("   ✓ 气候态插值完成")
else:
    print("   ✓ 目标数据与气候态网格形状一致")

if lat_name_clim != lat_name_target or lon_name_clim != lon_name_target:
    data_climatology = data_climatology.rename({
        lat_name_clim: lat_name_target,
        lon_name_clim: lon_name_target,
    })
    print("   ✓ 气候态维度名称已统一")

print("\n🔢 计算相对DOD异常百分比（0.1度分辨率）...")

values_target = data_target.values
values_clim = data_climatology.values
lats = data_target[lat_name_target].values
lons = data_target[lon_name_target].values

with np.errstate(divide="ignore", invalid="ignore"):
    percentage_values = values_target / values_clim * 100.0

percentage_values = np.where(np.isinf(percentage_values), np.nan, percentage_values)

percentage_da = xr.DataArray(
    percentage_values,
    coords={lat_name_target: lats, lon_name_target: lons},
    dims=[lat_name_target, lon_name_target],
    name="percentage_change",
)

print(f"   ✓ 百分比范围(0.1°): [{np.nanmin(percentage_values):.2f}%, {np.nanmax(percentage_values):.2f}%]")

print("\n🔄 进行3×3网格重采样（0.1° → 0.3°）...")

percentage_resampled = percentage_da.coarsen(
    {lat_name_target: 3, lon_name_target: 3},
    boundary="trim",
).mean()

percentage_03deg = percentage_resampled.values
lats_03deg = percentage_resampled[lat_name_target].values
lons_03deg = percentage_resampled[lon_name_target].values

print(f"   原始维度(0.1°): {percentage_da.shape}")
print(f"   重采样后(0.3°): {percentage_resampled.shape}")
print(f"   ✓ 百分比范围(0.3°): [{np.nanmin(percentage_03deg):.2f}%, {np.nanmax(percentage_03deg):.2f}%]")

print("\n🗺️ 对齐土地利用数据到0.3°结果网格...")

lat_match = (
    dominant_lc_da.sizes[lat_name_lc] == len(lats_03deg)
    and np.allclose(dominant_lc_da[lat_name_lc].values, lats_03deg, atol=0.01)
)

lon_match = (
    dominant_lc_da.sizes[lon_name_lc] == len(lons_03deg)
    and np.allclose(dominant_lc_da[lon_name_lc].values, lons_03deg, atol=0.01)
)

if not (lat_match and lon_match):
    print("   ⚠️ 土地利用坐标与0.3°结果网格不完全一致，进行最近邻插值...")
    dominant_lc_da = dominant_lc_da.interp(
        **{
            lat_name_lc: lats_03deg,
            lon_name_lc: lons_03deg,
        },
        method="nearest",
    )
    print("   ✓ 土地利用插值完成")
else:
    print("   ✓ 土地利用网格与结果网格一致")

dominant_lc = dominant_lc_da.values

print("\n📊 按土地利用类型提取数据（5-95百分位过滤）+ t检验...")

LAND_COVER_NAMES = ["Forest", "Shrubland", "Savannah", "Grassland", "Cropland", "Barren"]

LAND_COVER_COLORS = [
    "#1B5E20",
    "#558B2F",
    "#9E9D24",
    "#C0CA33",
    "#F9A825",
    "#BCAAA4",
]

land_type_data = []
land_type_stats = []

for i, land_name in enumerate(LAND_COVER_NAMES):
    mask = dominant_lc == i
    land_data = percentage_03deg[mask]
    land_valid = land_data[~np.isnan(land_data)]

    if len(land_valid) > 0:
        p5 = np.percentile(land_valid, 5)
        p95 = np.percentile(land_valid, 95)
        land_filtered = land_valid[(land_valid >= p5) & (land_valid <= p95)]

        n_original = len(land_valid)
        n_filtered = len(land_filtered)
        filtered_pct = 100 * n_filtered / n_original
    else:
        p5 = np.nan
        p95 = np.nan
        land_filtered = np.array([])
        n_original = 0
        n_filtered = 0
        filtered_pct = 0.0

    land_type_data.append(land_filtered)

    if len(land_filtered) > 1:
        t_statistic, p_value = stats.ttest_1samp(land_filtered, 0.0)

        if p_value < 0.001:
            significance = "***"
        elif p_value < 0.01:
            significance = "**"
        elif p_value < 0.05:
            significance = "*"
        else:
            significance = ""
    else:
        t_statistic = np.nan
        p_value = np.nan
        significance = ""

    if len(land_filtered) > 0:
        mean_val = np.mean(land_filtered)
        median_val = np.median(land_filtered)
        std_val = np.std(land_filtered)
        q25_val = np.percentile(land_filtered, 25)
        q75_val = np.percentile(land_filtered, 75)

        positive_count = np.sum(land_filtered > 0)
        negative_count = np.sum(land_filtered < 0)
        zero_count = np.sum(land_filtered == 0)

        positive_pct = 100 * positive_count / len(land_filtered)
        negative_pct = 100 * negative_count / len(land_filtered)
        zero_pct = 100 * zero_count / len(land_filtered)
    else:
        mean_val = np.nan
        median_val = np.nan
        std_val = np.nan
        q25_val = np.nan
        q75_val = np.nan

        positive_count = 0
        negative_count = 0
        zero_count = 0

        positive_pct = 0.0
        negative_pct = 0.0
        zero_pct = 0.0

    stats_info = {
        "name": land_name,
        "n_original": n_original,
        "n_filtered": n_filtered,
        "filtered_pct": filtered_pct,
        "p5": p5,
        "p95": p95,
        "mean": mean_val,
        "median": median_val,
        "std": std_val,
        "q25": q25_val,
        "q75": q75_val,
        "positive_count": positive_count,
        "negative_count": negative_count,
        "zero_count": zero_count,
        "positive_pct": positive_pct,
        "negative_pct": negative_pct,
        "zero_pct": zero_pct,
        "t_statistic": t_statistic,
        "p_value": p_value,
        "significance": significance,
    }

    land_type_stats.append(stats_info)

    p_show = f"{p_value:.4f}" if not np.isnan(p_value) else "N/A"

    print(
        f"   {land_name:12s}: {n_original:8,} → {n_filtered:8,} 像元 "
        f"({filtered_pct:5.1f}%) | 均值={mean_val:7.2f}% | "
        f"t={t_statistic:7.2f}, p={p_show} {significance}"
    )

print("\n🎨 绘制土地利用类型小提琴图...")


def lighten_color(color, amount=0.65):
    import matplotlib.colors as mcolors

    c = np.array(mcolors.to_rgb(color))
    white = np.array([1, 1, 1])
    return tuple(c + (white - c) * amount)


plt.rcParams.update({
    "font.family": FONT_FAMILY,
    "font.size": FS_BASE,
    "axes.linewidth": AXES_LINEWIDTH,
    "xtick.major.width": TICK_WIDTH,
    "ytick.major.width": TICK_WIDTH,
    "xtick.major.size": TICK_LENGTH,
    "ytick.major.size": TICK_LENGTH,
    "figure.dpi": 300,
})

fig, ax = plt.subplots(figsize=(FIG_WIDTH, FIG_HEIGHT))
positions = np.arange(len(LAND_COVER_NAMES))

parts = ax.violinplot(
    land_type_data,
    positions=positions,
    widths=VIOLIN_WIDTH,
    showmeans=False,
    showmedians=False,
    showextrema=False,
)

for i, pc in enumerate(parts["bodies"]):
    pc.set_facecolor(LAND_COVER_COLORS[i])
    pc.set_edgecolor(LAND_COVER_COLORS[i])
    pc.set_linewidth(0.5)
    pc.set_alpha(0.75)

bp = ax.boxplot(
    land_type_data,
    positions=positions,
    widths=BOXPLOT_WIDTH,
    patch_artist=True,
    showfliers=False,
    medianprops=dict(color="black", linewidth=2),
    boxprops=dict(facecolor="white", edgecolor="black", linewidth=1.5, alpha=0.95),
    whiskerprops=dict(color="black", linewidth=1.5),
    capprops=dict(color="none", linewidth=0),
)

for i, box in enumerate(bp["boxes"]):
    light_color = lighten_color(LAND_COVER_COLORS[i], amount=0.65)
    box.set_facecolor(light_color)
    box.set_edgecolor(LAND_COVER_COLORS[i])
    box.set_linewidth(1.5)
    box.set_alpha(0.95)

all_data_concat = (
    np.concatenate([d for d in land_type_data if len(d) > 0])
    if any(len(d) > 0 for d in land_type_data)
    else np.array([-1, 1])
)

y_min_data = np.nanmin(all_data_concat)
y_max_data = np.nanmax(all_data_concat)
y_pad = 0.15 * (y_max_data - y_min_data if y_max_data > y_min_data else 1.0)

ax.set_ylim(y_min_data - y_pad, y_max_data + y_pad * 1.6)

current_ylim = ax.get_ylim()
y_range = current_ylim[1] - current_ylim[0]
offset = y_range * 0.004

for i, stats_info in enumerate(land_type_stats):
    if not np.isnan(stats_info["median"]) and len(land_type_data[i]) > 0:
        y_pos = stats_info["median"]
        ax.text(
            i,
            y_pos + offset,
            f"{stats_info['median']:.1f}%",
            ha="center",
            va="bottom",
            fontsize=FS_MEDIAN_TEXT,
            fontweight="semibold",
            color="black",
        )

ax.axhline(y=0, color="#616161", linestyle="--", linewidth=1.4, alpha=0.9, zorder=0)

ax.set_xticks(positions)
ax.set_xticklabels(LAND_COVER_NAMES, fontsize=FS_XTICK)
ax.set_ylabel(
    "Relative DOD Anomaly (%)\n(Anomaly vs. Climatology)",
    fontsize=FS_AXIS_LABEL,
)

ax.tick_params(axis="y", labelsize=FS_YTICK)
ax.tick_params(axis="x", labelsize=FS_XTICK)

ax.yaxis.grid(False)
ax.set_axisbelow(True)

current_ylim = ax.get_ylim()
y_bottom, y_top = current_ylim
y_range = y_top - y_bottom

y_position_sig = y_top - y_range * 0.14
y_position_n = y_top - y_range * 0.08

for i, stats_info in enumerate(land_type_stats):
    if len(land_type_data[i]) > 0:
        ax.text(
            i,
            y_position_n,
            f"n={stats_info['n_filtered']:,}",
            ha="center",
            va="bottom",
            fontsize=FS_SAMPLE_N,
            color="#424242",
        )

    if stats_info["significance"]:
        ax.text(
            i,
            y_position_sig,
            stats_info["significance"],
            ha="center",
            va="bottom",
            fontsize=FS_SIGNIFICANCE,
            fontweight="bold",
            color="black",
        )

ax.set_xlim(-0.5, len(LAND_COVER_NAMES) - 0.5)

ax.text(
    -0.1,
    1.02,
    "b",
    transform=ax.transAxes,
    fontsize=FS_PANEL,
    fontweight="bold",
    va="top",
    ha="left",
    bbox=dict(
        boxstyle="round,pad=0.3",
        facecolor="white",
        edgecolor="none",
        alpha=0.8,
    ),
)

plt.tight_layout()

output_path = r"L:\FD_Data_Process\Figures\闪旱期间DOD异常值\dod_landcover_violin_filtered_vs_climatology.png"
plt.savefig(output_path, dpi=300, bbox_inches="tight")
print(f"\n💾 图片已保存: {output_path}")

plt.show()

print("\n📈 详细统计表（5–95百分位过滤后，0.3度分辨率）:")
print(
    f"{'Land Cover':<12} {'Original':>10} {'Filtered':>10} {'P5':>8} "
    f"{'P95':>8} {'Mean':>8} {'Median':>8} {'Std':>8} {'t-value':>8} "
    f"{'p-value':>10} {'Sig':>5} {'Positive%':>10} {'Negative%':>10}"
)
print("-" * 150)

for stats_info in land_type_stats:
    p_display = f"{stats_info['p_value']:.4f}" if not np.isnan(stats_info["p_value"]) else "N/A"

    if not np.isnan(stats_info["p_value"]) and stats_info["p_value"] < 0.0001:
        p_display = "<0.0001"

    print(
        f"{stats_info['name']:<12} "
        f"{stats_info['n_original']:>10,} "
        f"{stats_info['n_filtered']:>10,} "
        f"{stats_info['p5']:>8.2f} "
        f"{stats_info['p95']:>8.2f} "
        f"{stats_info['mean']:>8.2f} "
        f"{stats_info['median']:>8.2f} "
        f"{stats_info['std']:>8.2f} "
        f"{stats_info['t_statistic']:>8.2f} "
        f"{p_display:>10} "
        f"{stats_info['significance']:>5} "
        f"{stats_info['positive_pct']:>10.1f} "
        f"{stats_info['negative_pct']:>10.1f}"
    )

print("\n📊 科学解释:")
print("=" * 80)
print("正值: 表明闪旱筛选事件期间的DOD高于气候态")
print("负值: 表明闪旱筛选事件期间的DOD低于气候态")
print("\n统计显著性:")
print("  *** : p < 0.001 (极显著)")
print("  **  : p < 0.01  (高度显著)")
print("  *   : p < 0.05  (显著)")
print("  (空): p ≥ 0.05 (不显著)")
print("=" * 80)

print("\n✅ 完成!")

ds_target.close()
ds_clim.close()
ds_lc.close()