#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import warnings
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
import pandas as pd
import xarray as xr
from scipy import stats
from scipy.stats import norm, t

warnings.filterwarnings("ignore")

FONT_FAMILY = "Arial"
FS_LABEL = 32
FS_TICK = 30
FS_LEGEND = 26
FS_PANEL = 50
FS_TEXT = 30
FS_TITLE = 24

plt.rcParams.update({
    "font.family": FONT_FAMILY,
    "font.size": FS_TEXT,
    "axes.labelsize": FS_LABEL,
    "xtick.labelsize": FS_TICK,
    "ytick.labelsize": FS_TICK,
    "legend.fontsize": FS_LEGEND,
})


def mann_kendall_test(data):
    data = np.asarray(data, dtype=float)
    data = data[np.isfinite(data)]

    n = len(data)
    if n < 2:
        return "No trend", np.nan, np.nan, np.nan

    s = 0
    for i in range(n - 1):
        for j in range(i + 1, n):
            s += np.sign(data[j] - data[i])

    _, counts = np.unique(data, return_counts=True)

    var_s = n * (n - 1) * (2 * n + 5)

    for count in counts[counts > 1]:
        var_s -= count * (count - 1) * (2 * count + 5)

    var_s /= 18.0

    if var_s <= 0:
        return "No trend", 1.0, 0.0, 0.0

    if s > 0:
        z = (s - 1) / np.sqrt(var_s)
    elif s < 0:
        z = (s + 1) / np.sqrt(var_s)
    else:
        z = 0.0

    p_value = 2 * (1 - norm.cdf(abs(z)))
    tau = s / (0.5 * n * (n - 1))

    trend = "Upward" if p_value < 0.05 and s > 0 else "Downward" if p_value < 0.05 else "No trend"

    return trend, p_value, tau, z


def get_significance_symbol(p_value):
    if np.isnan(p_value):
        return "nan"
    if p_value < 0.001:
        return "***"
    if p_value < 0.01:
        return "**"
    if p_value < 0.05:
        return "*"
    return "ns"


def load_drought_dod_timeseries(nc_file, use_filtered=True):
    print("=" * 60)
    print("从 NetCDF 文件加载数据...")
    print(f"文件路径: {nc_file}")
    print("=" * 60)

    ds = xr.open_dataset(nc_file)

    print("\nNetCDF文件中的变量:")
    print(f"  {list(ds.variables.keys())}\n")

    time_index = ds["pentad_index"].values

    required_vars = [
        "global_mean_dod_filtered",
        "global_mean_dod_raw",
        "sample_count_drought_pixels",
    ]

    for var in required_vars:
        if var not in ds.variables:
            raise ValueError(f"未找到变量: {var}")

    global_mean_dod_filtered = ds["global_mean_dod_filtered"].values
    global_mean_dod_raw = ds["global_mean_dod_raw"].values
    sample_count = ds["sample_count_drought_pixels"].values

    retained_count = (
        ds["retained_count_after_filter"].values
        if "retained_count_after_filter" in ds.variables
        else np.full_like(sample_count, np.nan)
    )

    zeroed_count = (
        ds["zeroed_count_after_filter"].values
        if "zeroed_count_after_filter" in ds.variables
        else np.full_like(sample_count, np.nan)
    )

    if use_filtered:
        global_mean_dod = global_mean_dod_filtered
        print("使用 DOD filtered 数据（真正反映第二段筛选结果）")
    else:
        global_mean_dod = global_mean_dod_raw
        print("使用 DOD raw 数据（筛选前原始序列）")

    if "time" in ds.coords:
        dates = pd.to_datetime(ds["time"].values).strftime("%Y-%m-%d").tolist()
    elif "days_since_2003" in ds.variables:
        reference_date = pd.Timestamp("2003-01-01")
        days = ds["days_since_2003"].values
        dates = [
            (reference_date + pd.Timedelta(days=int(d))).strftime("%Y-%m-%d")
            for d in days
        ]
    else:
        reference_date = pd.Timestamp("2003-01-01")
        dates = [
            (reference_date + pd.Timedelta(days=int(i * 5))).strftime("%Y-%m-%d")
            for i in time_index
        ]

    ds.close()

    valid_pentads = np.sum(~np.isnan(global_mean_dod))
    total_samples = np.nansum(sample_count)

    print(f"\n{'=' * 60}")
    print("数据加载完成！")
    print(f"{'=' * 60}")
    print(f"时间范围: {len(time_index)} pentads")
    print(f"日期范围: {dates[0]} 至 {dates[-1]}")
    print(f"有效pentad数: {valid_pentads}/{len(time_index)}")
    print(f"总样本数: {int(total_samples):,}")

    if valid_pentads > 0:
        print(f"平均样本数/pentad: {total_samples / valid_pentads:.1f}")

        positive_sample_mask = sample_count > 0
        if np.any(positive_sample_mask):
            print(f"样本数范围: {sample_count[positive_sample_mask].min()} - {sample_count.max()}")

        print(f"当前使用序列范围: {np.nanmin(global_mean_dod):.4f} - {np.nanmax(global_mean_dod):.4f}")
        print(f"原始序列范围: {np.nanmin(global_mean_dod_raw):.4f} - {np.nanmax(global_mean_dod_raw):.4f}")
        print(f"筛后序列范围: {np.nanmin(global_mean_dod_filtered):.4f} - {np.nanmax(global_mean_dod_filtered):.4f}")

    if np.all(np.isfinite(retained_count)) and np.all(np.isfinite(zeroed_count)):
        print(f"总保留样本数: {int(np.nansum(retained_count)):,}")
        print(f"总置零样本数: {int(np.nansum(zeroed_count)):,}")

    print(f"{'=' * 60}\n")

    return (
        time_index,
        global_mean_dod,
        sample_count,
        retained_count,
        zeroed_count,
        dates,
        global_mean_dod_raw,
        global_mean_dod_filtered,
    )


def plot_global_drought_dod_timeseries(
    time_index,
    global_mean_dod,
    sample_count,
    dates,
    series_name="Filtered DOD",
    raw_series=None,
    filtered_series=None,
):
    print("开始绘图...")

    date_time = pd.to_datetime(dates)
    years = date_time.year.values
    unique_years = np.arange(years.min(), years.max() + 1)

    window_size = 6

    if len(global_mean_dod) >= window_size:
        smooth_dod = pd.Series(global_mean_dod).rolling(
            window=window_size,
            center=True,
            min_periods=1,
        ).mean().values
    else:
        smooth_dod = np.asarray(global_mean_dod, dtype=float)

    fig, (ax1, ax2) = plt.subplots(
        2,
        1,
        figsize=(26, 13),
        gridspec_kw={"height_ratios": [3, 1]},
    )

    ax1.axhline(y=0, color="gray", linestyle="--", linewidth=1, alpha=0.5, zorder=2)

    COLOR_POSITIVE = "#E74C3C"
    COLOR_NEGATIVE = "#3498DB"
    ALPHA = 0.6

    ax1.fill_between(
        date_time,
        0,
        smooth_dod,
        where=smooth_dod >= 0,
        color=COLOR_POSITIVE,
        alpha=ALPHA,
        interpolate=True,
        label="Positive Anomaly",
        zorder=2.5,
    )

    ax1.fill_between(
        date_time,
        smooth_dod,
        0,
        where=smooth_dod < 0,
        color=COLOR_NEGATIVE,
        alpha=ALPHA,
        interpolate=True,
        label="Negative Anomaly",
        zorder=2.5,
    )

    ax1.plot(
        date_time,
        smooth_dod,
        linewidth=1,
        color="black",
        label=f"{window_size}-pentad Moving Average (~1 month)",
        alpha=0.9,
        zorder=5,
    )

    if raw_series is not None and filtered_series is not None:
        raw_smooth = pd.Series(raw_series).rolling(
            window=window_size,
            center=True,
            min_periods=1,
        ).mean().values

        ax1.plot(
            date_time,
            raw_smooth,
            linewidth=1.0,
            color="gray",
            linestyle="-",
            alpha=0.45,
            zorder=4,
            label="Raw DOD (smoothed)",
        )

    annual_positive_area = []
    annual_negative_area = []

    for year in unique_years:
        year_smooth = smooth_dod[years == year]
        annual_positive_area.append(np.sum(year_smooth[year_smooth > 0]))
        annual_negative_area.append(np.abs(np.sum(year_smooth[year_smooth < 0])))

    annual_positive_area = np.array(annual_positive_area, dtype=float)
    annual_negative_area = np.array(annual_negative_area, dtype=float)
    annual_net_area = annual_positive_area - annual_negative_area

    ax1.set_ylabel("Global Mean DOD Anomaly", fontsize=FS_LABEL, fontweight="normal")
    ax1.text(
        -0.07,
        1,
        "d",
        transform=ax1.transAxes,
        fontsize=FS_PANEL,
        fontweight="bold",
        va="top",
        ha="left",
    )

    ax1.legend(
        loc="upper left",
        fontsize=FS_LEGEND,
        framealpha=0,
        bbox_to_anchor=(0, 1.04),
    )

    ax1.grid(False)
    ax1.set_xlim(date_time[0], date_time[-1])

    valid_annual = np.isfinite(annual_net_area)

    if np.sum(valid_annual) >= 2:
        x = unique_years[valid_annual]
        y = annual_net_area[valid_annual]

        slope_net, intercept_net, r_value_net, p_value_lr_net, std_err_net = stats.linregress(x, y)
        r_squared_net = r_value_net ** 2
        trend_line_net = slope_net * unique_years + intercept_net
        sig_symbol_lr_net = get_significance_symbol(p_value_lr_net)

        mk_trend_net, p_value_mk_net, tau_net, z_score_net = mann_kendall_test(y)
        sig_symbol_mk_net = get_significance_symbol(p_value_mk_net)

        n = len(x)
        residuals = y - (slope_net * x + intercept_net)
        mse = np.sum(residuals ** 2) / (n - 2) if n > 2 else 0.0

        x_mean = np.mean(x)
        x_dev_all = unique_years - x_mean
        denom = np.sum((x - x_mean) ** 2)

        if n > 2 and denom > 0:
            se = np.sqrt(mse * (1 / n + x_dev_all ** 2 / denom))
            t_critical = t.ppf(0.975, n - 2)
            ci_upper = trend_line_net + t_critical * se
            ci_lower = trend_line_net - t_critical * se
        else:
            t_critical = np.nan
            ci_upper = trend_line_net
            ci_lower = trend_line_net
    else:
        slope_net = intercept_net = r_squared_net = p_value_lr_net = std_err_net = np.nan
        mk_trend_net = "No trend"
        p_value_mk_net = tau_net = z_score_net = np.nan
        sig_symbol_lr_net = sig_symbol_mk_net = "nan"
        trend_line_net = np.full_like(unique_years, np.nan, dtype=float)
        ci_upper = trend_line_net.copy()
        ci_lower = trend_line_net.copy()
        t_critical = np.nan

    bar_width = 0.7

    ax2.bar(
        unique_years,
        annual_positive_area,
        bar_width,
        color=COLOR_POSITIVE,
        alpha=0.7,
        edgecolor=COLOR_POSITIVE,
        linewidth=1.5,
    )

    ax2.bar(
        unique_years,
        -annual_negative_area,
        bar_width,
        color=COLOR_NEGATIVE,
        alpha=0.7,
        edgecolor=COLOR_NEGATIVE,
        linewidth=1.5,
    )

    ax2.axhline(y=0, color="gray", linestyle="-", linewidth=1.5, alpha=0.6, zorder=3)

    ax2.plot(
        unique_years,
        annual_net_area,
        color="black",
        linestyle="-",
        linewidth=4,
        marker="o",
        markersize=12,
        markerfacecolor="black",
        markeredgecolor="white",
        markeredgewidth=1.5,
        label="Net Value (Pos. minus Neg.)",
        zorder=4,
        alpha=0.9,
    )

    trend_color = "#8E44AD"

    both_significant = (
        np.isfinite(p_value_lr_net)
        and p_value_lr_net < 0.05
        and np.isfinite(p_value_mk_net)
        and p_value_mk_net < 0.05
    )

    one_significant = (
        np.isfinite(p_value_lr_net)
        and p_value_lr_net < 0.05
    ) or (
        np.isfinite(p_value_mk_net)
        and p_value_mk_net < 0.05
    )

    if both_significant:
        trend_linewidth = 4
        trend_alpha = 0.9
        ci_alpha = 0.25
        trend_label = "Net Value Trend (highly significant)"
    elif one_significant:
        trend_linewidth = 2.0
        trend_alpha = 0.8
        ci_alpha = 0.20
        trend_label = "Net Value Trend (one test significant)"
    else:
        trend_linewidth = 1.5
        trend_alpha = 0.6
        ci_alpha = 0.15
        trend_label = "Net Value Trend (not significant)"

    if np.any(np.isfinite(ci_upper)) and np.any(np.isfinite(ci_lower)):
        ax2.fill_between(
            unique_years,
            ci_lower,
            ci_upper,
            color=trend_color,
            alpha=ci_alpha,
            edgecolor="none",
            zorder=3,
            label="95% Confidence Interval",
        )

    if np.any(np.isfinite(trend_line_net)):
        ax2.plot(
            unique_years,
            trend_line_net,
            linestyle="--",
            color=trend_color,
            linewidth=trend_linewidth,
            alpha=trend_alpha,
            label=trend_label,
            zorder=5,
        )

    print(f"\n{'=' * 60}")
    print(f"{series_name} 净面积趋势显著性分析")
    print(f"{'=' * 60}")

    print("\n【线性回归分析】")
    print(f"  斜率: {slope_net:+.6f} per year")
    print(f"  截距: {intercept_net:.4f}")
    print(f"  R²: {r_squared_net:.4f}")
    print(f"  标准误差: {std_err_net:.6f}")
    print(f"  p-value: {p_value_lr_net:.6f} {sig_symbol_lr_net}")

    if np.isfinite(t_critical) and np.isfinite(std_err_net):
        print(f"  95% CI斜率: [{slope_net - t_critical * std_err_net:+.6f}, {slope_net + t_critical * std_err_net:+.6f}]")

    if np.isfinite(p_value_lr_net):
        print(f"  结论: 显著{'上升' if slope_net > 0 else '下降'}趋势" if p_value_lr_net < 0.05 else "  结论: 无显著趋势")

    print("\n【Mann-Kendall检验】")
    print(f"  趋势: {mk_trend_net}")
    print(f"  Kendall's tau: {tau_net:.4f}")
    print(f"  Z-score: {z_score_net:.4f}")
    print(f"  p-value: {p_value_mk_net:.6f} {sig_symbol_mk_net}")

    if np.isfinite(p_value_mk_net):
        print(f"  结论: 显著{mk_trend_net.lower()}趋势" if p_value_mk_net < 0.05 else "  结论: 无显著趋势")

    print("\n【综合结论】")
    if both_significant:
        print("  两种检验均显示显著趋势 (p<0.05)")
    elif one_significant:
        print("  一种检验显示显著趋势")
    else:
        print("  两种检验均未显示显著趋势")

    print(f"\n{'=' * 60}")
    print("年度正负面积统计")
    print(f"{'=' * 60}")
    print(f"总正值面积: {np.sum(annual_positive_area):.4f}")
    print(f"总负值面积: {np.sum(annual_negative_area):.4f}")
    print(f"总净面积: {np.sum(annual_net_area):.4f}")
    print(f"正值面积均值: {np.mean(annual_positive_area):.4f} ± {np.std(annual_positive_area):.4f}")
    print(f"负值面积均值: {np.mean(annual_negative_area):.4f} ± {np.std(annual_negative_area):.4f}")
    print(f"净面积均值: {np.mean(annual_net_area):.4f} ± {np.std(annual_net_area):.4f}")

    max_pos_year = unique_years[np.argmax(annual_positive_area)]
    max_neg_year = unique_years[np.argmax(annual_negative_area)]
    max_net_year = unique_years[np.argmax(annual_net_area)]
    min_net_year = unique_years[np.argmin(annual_net_area)]

    print(f"\n最大正值面积年份: {max_pos_year} ({annual_positive_area.max():.4f})")
    print(f"最大负值面积年份: {max_neg_year} ({annual_negative_area.max():.4f})")
    print(f"最大净面积年份: {max_net_year} ({annual_net_area.max():.4f})")
    print(f"最小净面积年份: {min_net_year} ({annual_net_area.min():.4f})")
    print(f"{'=' * 60}\n")

    ax2.set_xlabel("Year", fontsize=FS_LABEL, fontweight="normal")
    ax2.set_ylabel(
        "Annual DOD Anomaly",
        fontsize=FS_LABEL,
        fontweight="normal",
        labelpad=40,
    )

    ax2.legend(
        loc="upper left",
        fontsize=FS_LEGEND,
        framealpha=0,
        ncol=2,
        bbox_to_anchor=(0, 1.1),
    )

    ax2.grid(False)
    ax2.set_xlim(unique_years[0] - 0.5, unique_years[-1] + 0.5)
    ax2.set_xticks(unique_years)
    ax2.set_xticklabels(unique_years, rotation=45, ha="right")
    ax2.tick_params(axis="x", labelsize=FS_TICK)
    ax2.set_ylim(-0.5, 2)

    ax1.tick_params(axis="both", labelsize=FS_TICK)
    ax1.xaxis.set_major_locator(mdates.YearLocator())
    ax1.xaxis.set_major_formatter(mdates.DateFormatter("%Y"))
    ax1.xaxis.set_minor_locator(mdates.MonthLocator())

    ax2.tick_params(axis="both", labelsize=FS_TICK)

    plt.tight_layout()

    output_dir = r"L:\FD_Data_Process\Figures\闪旱期间DOD异常值"
    os.makedirs(output_dir, exist_ok=True)

    png_file = os.path.join(output_dir, "global_drought_dod_timeseries_reflect_filtered_v52.png")
    plt.savefig(png_file, dpi=300, bbox_inches="tight", facecolor="white")
    print(f"✓ 图片已保存: {png_file}")

    plt.show()
    print("✓ 绘图完成\n")


def main():
    nc_file = r"L:/FD_Data_Process/FD_TimeSeries/global_drought_dod_timeseries_reflect_filtered_v52.nc"
    use_filtered = True

    (
        time_index,
        global_mean_dod,
        sample_count,
        retained_count,
        zeroed_count,
        dates,
        global_mean_dod_raw,
        global_mean_dod_filtered,
    ) = load_drought_dod_timeseries(nc_file, use_filtered=use_filtered)

    plot_global_drought_dod_timeseries(
        time_index=time_index,
        global_mean_dod=global_mean_dod,
        sample_count=sample_count,
        dates=dates,
        series_name="Filtered DOD" if use_filtered else "Raw DOD",
        raw_series=global_mean_dod_raw,
        filtered_series=global_mean_dod_filtered,
    )

    print("=" * 60)
    print("全部完成！")
    print("=" * 60)


if __name__ == "__main__":
    main()