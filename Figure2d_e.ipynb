# -*- coding: utf-8 -*-

import os
import numpy as np
import matplotlib.pyplot as plt


INPUT_DIR = r"L:\FD_Data_Process\Figures\EVI_WindPercent_EventLevel_DODThreshold_ULTRAFAST"
SUFFIX = "DODge90_eventlevel_completeWind"
INPUT_NPZ = os.path.join(INPUT_DIR, f"binned_result_{SUFFIX}.npz")

OUTPUT_DIR = r"L:\FD_Data_Process\Figures\闪旱伴随强沙尘事件"
os.makedirs(OUTPUT_DIR, exist_ok=True)

OUTPUT_PNG = os.path.join(OUTPUT_DIR, f"scatter_piecewise_autoBIC_{SUFFIX}_countge100.png")
OUTPUT_PDF = os.path.join(OUTPUT_DIR, f"scatter_piecewise_autoBIC_{SUFFIX}_countge100.pdf")

MIN_COUNT = 100

FIG_W, FIG_H, DPI = 13, 5.5, 400
SHOW_FIG = True
SAVE_FIG = True

POINT_SIZE_MIN, POINT_SIZE_MAX = 18, 140
AUTO_COLOR_RANGE = False
PROB_VMIN, PROB_VMAX = 5, 30
POINT_ALPHA = 0.80
SCATTER_CMAP = "RdYlBu_r"

AUTO_SELECT_EVI = True
CANDIDATE_SEGMENTS = [1, 2, 3, 4]
N_SEGMENTS_EVI = 3

N_SEGMENTS_WIND_SEARCH = 3
WIND_KEEP_BP_INDEX = -1

N_BOOTSTRAP = 200
CI_LEVEL = 0.95
BP_GRID_STEP = 1.0


def _fit_segments_given_bp(x, y, w, breakpoints):
    all_bp = np.concatenate([[x.min() - 1e-9], breakpoints, [x.max() + 1e-9]])
    total_sse = 0.0
    params = []
    n_params = 0

    for i in range(len(all_bp) - 1):
        if i < len(all_bp) - 2:
            mask = (x >= all_bp[i]) & (x < all_bp[i + 1])
        else:
            mask = (x >= all_bp[i]) & (x <= all_bp[i + 1])

        xs, ys, ws = x[mask], y[mask], w[mask]

        if len(xs) < 2:
            total_sse += 1e12
            params.append((0.0, 0.0))
            n_params += 2
            continue

        X = np.column_stack([np.ones_like(xs), xs])
        W = np.diag(ws)
        beta = np.linalg.lstsq(W @ X, W @ ys, rcond=None)[0]
        resid = ys - X @ beta

        total_sse += float(ws @ (resid ** 2))
        params.append((float(beta[1]), float(beta[0])))
        n_params += 2

    n_params += len(breakpoints)

    return total_sse, n_params, params


def fit_piecewise_grid(x, y, w, n_segments, grid_step=1.0):
    order = np.argsort(x)
    x, y, w = x[order], y[order], w[order]

    if n_segments == 1:
        sse, n_params, params = _fit_segments_given_bp(x, y, w, [])
        full_bp = np.array([x.min(), x.max()])
        return full_bp, [params[0][0]], [params[0][1]], sse, n_params

    x_lo = np.percentile(x, 10)
    x_hi = np.percentile(x, 90)
    candidates = np.arange(x_lo, x_hi + grid_step * 0.5, grid_step)

    n_bp = n_segments - 1
    best_sse = np.inf
    best_bp = None

    if n_bp == 1:
        for bp1 in candidates:
            sse, _, _ = _fit_segments_given_bp(x, y, w, [bp1])
            if sse < best_sse:
                best_sse = sse
                best_bp = [bp1]

    elif n_bp == 2:
        for i, bp1 in enumerate(candidates[:-1]):
            for bp2 in candidates[i + 1:]:
                if bp2 - bp1 < grid_step * 2:
                    continue
                sse, _, _ = _fit_segments_given_bp(x, y, w, [bp1, bp2])
                if sse < best_sse:
                    best_sse = sse
                    best_bp = [bp1, bp2]

    elif n_bp == 3:
        for i, bp1 in enumerate(candidates[:-2]):
            for j, bp2 in enumerate(candidates[i + 1:-1], start=i + 1):
                if bp2 - bp1 < grid_step * 2:
                    continue
                for bp3 in candidates[j + 1:]:
                    if bp3 - bp2 < grid_step * 2:
                        continue
                    sse, _, _ = _fit_segments_given_bp(x, y, w, [bp1, bp2, bp3])
                    if sse < best_sse:
                        best_sse = sse
                        best_bp = [bp1, bp2, bp3]
    else:
        raise NotImplementedError("最多支持 4 段（3 个断点）")

    sse_final, n_params, params = _fit_segments_given_bp(x, y, w, best_bp)
    full_bp = np.array([x.min()] + best_bp + [x.max()])
    slopes = [p[0] for p in params]
    intercepts = [p[1] for p in params]

    return full_bp, slopes, intercepts, sse_final, n_params


def compute_bic(sse, n, k):
    if sse <= 0 or n <= k:
        return np.inf
    return n * np.log(sse / n) + k * np.log(n)


def auto_select_segments(x, y, w, candidate_segments, grid_step=1.0, label=""):
    n = len(x)
    results = {}
    best_bic = np.inf
    best_nseg = None

    print(f"\n  [{label}] BIC 模型选择:")
    print(f"  {'段数':>4s}  {'断点数':>4s}  {'参数数':>4s}  {'SSE':>12s}  {'BIC':>12s}  {'备注'}")
    print(f"  {'-' * 60}")

    for nseg in candidate_segments:
        try:
            full_bp, slopes, intercepts, sse, n_params = fit_piecewise_grid(
                x, y, w, nseg, grid_step=grid_step
            )
            bic = compute_bic(sse, n, n_params)

            results[nseg] = {
                "full_bp": full_bp,
                "slopes": slopes,
                "intercepts": intercepts,
                "sse": sse,
                "n_params": n_params,
                "bic": bic
            }

            marker = ""
            if bic < best_bic:
                best_bic = bic
                best_nseg = nseg
                marker = " ← current best"

            print(f"  {nseg:>4d}  {nseg - 1:>4d}  {n_params:>4d}  {sse:>12.2f}  {bic:>12.2f}{marker}")

        except Exception as e:
            print(f"  {nseg:>4d}  —  拟合失败: {e}")

    print(f"\n  ★ 最优分段数 = {best_nseg}（BIC = {best_bic:.2f}）")

    return best_nseg, results[best_nseg]


def predict_piecewise(x_new, breakpoints, slopes, intercepts):
    y_new = np.empty_like(x_new)

    for i in range(len(slopes)):
        if i < len(slopes) - 1:
            mask = (x_new >= breakpoints[i]) & (x_new < breakpoints[i + 1])
        else:
            mask = (x_new >= breakpoints[i]) & (x_new <= breakpoints[i + 1])

        y_new[mask] = intercepts[i] + slopes[i] * x_new[mask]

    return y_new


def bootstrap_breakpoints(x, y, w, n_segments, n_boot=200, ci=0.95, grid_step=1.0, label=""):
    n = len(x)
    n_bp = n_segments - 1

    if n_bp == 0:
        print(f"    [{label}] 线性模型无断点，跳过 bootstrap")
        return np.array([]), np.array([]), np.array([])

    bp_list = []

    for i in range(n_boot):
        idx = np.random.choice(n, size=n, replace=True)

        try:
            full_bp, _, _, _, _ = fit_piecewise_grid(
                x[idx], y[idx], w[idx], n_segments, grid_step=grid_step
            )
            bp_list.append(full_bp[1:-1])
        except Exception:
            continue

        if (i + 1) % 50 == 0:
            print(f"    [{label}] bootstrap {i + 1}/{n_boot}  (success: {len(bp_list)})")

    if len(bp_list) < 30:
        print(f"  ⚠ 仅成功 {len(bp_list)} 次")

    bp_arr = np.array(bp_list)
    alpha = (1 - ci) / 2

    return (
        np.median(bp_arr, axis=0),
        np.percentile(bp_arr, 100 * alpha, axis=0),
        np.percentile(bp_arr, 100 * (1 - alpha), axis=0)
    )


def apply_nature_style():
    plt.rcParams.update({
        "font.family": "Arial",
        "font.size": 10,
        "axes.labelsize": 13,
        "axes.titlesize": 12,
        "axes.linewidth": 0.9,
        "xtick.labelsize": 11,
        "ytick.labelsize": 11,
        "xtick.direction": "out",
        "ytick.direction": "out",
        "xtick.major.size": 4.5,
        "ytick.major.size": 4.5,
        "xtick.major.width": 0.9,
        "ytick.major.width": 0.9,
        "legend.fontsize": 10,
        "figure.facecolor": "white",
        "axes.facecolor": "white",
        "savefig.facecolor": "white",
        "savefig.bbox": "tight",
        "pdf.fonttype": 42,
        "ps.fonttype": 42,
    })


def format_panel(ax, xlabel, ylabel):
    ax.set_xlabel(xlabel, labelpad=6)
    ax.set_ylabel(ylabel, labelpad=6)
    ax.set_xlim(0, 100)
    ax.set_xticks(np.arange(0, 101, 20))

    for s in ["left", "right", "top", "bottom"]:
        ax.spines[s].set_visible(True)
        ax.spines[s].set_linewidth(0.9)

    ax.tick_params(
        axis="both",
        which="major",
        top=False,
        right=False,
        direction="out",
        length=4.5,
        width=0.9,
        pad=3
    )


def load_binned_npz(f):
    d = np.load(f)

    return {
        "x_bins": d["x_bins"],
        "y_bins": d["y_bins"],
        "z_mean": d["z_mean"],
        "counts": d["counts"].astype(np.int32),
        "n_total": int(d["n_total"][0]),
        "n_pos": int(d["n_pos"][0]),
        "n_neg": int(d["n_neg"][0]),
        "n_events": int(d["n_events"][0]),
    }


def get_bin_centers(edges):
    return 0.5 * (edges[:-1] + edges[1:])


def size_from_counts(c, smin=18, smax=140):
    c = np.asarray(c, float)
    lo, hi = np.nanmin(c), np.nanmax(c)

    if np.isclose(lo, hi):
        return np.full(c.shape, 0.5 * (smin + smax))

    return smin + (c - lo) / (hi - lo) * (smax - smin)


def build_scatter_arrays(pd):
    ec = get_bin_centers(pd["x_bins"])
    wc = get_bin_centers(pd["y_bins"])
    p2 = pd["z_mean"]
    c2 = pd["counts"]
    vm = np.isfinite(p2) & np.isfinite(c2) & (c2 >= MIN_COUNT)

    if not np.any(vm):
        raise ValueError("无有效箱体")

    eg = np.tile(ec.reshape(1, -1), (len(wc), 1))
    wg = np.tile(wc.reshape(-1, 1), (1, len(ec)))

    return eg[vm], wg[vm], p2[vm], c2[vm]


def compute_weighted_marginal(x, p, c):
    ux = np.unique(x)
    mp = np.empty_like(ux)
    tw = np.empty_like(ux)

    for i, v in enumerate(ux):
        m = x == v
        w = c[m].astype(float)
        mp[i] = np.average(p[m], weights=w)
        tw[i] = w.sum()

    return ux, mp, tw


def main():
    plot_data = load_binned_npz(INPUT_NPZ)
    evi_s, wind_s, prob_s, cnt_s = build_scatter_arrays(plot_data)

    print(f"有效散点数: {len(prob_s):,}")
    print(f"概率范围: [{prob_s.min():.2f}, {prob_s.max():.2f}] %")

    evi_u, prob_evi, w_evi = compute_weighted_marginal(evi_s, prob_s, cnt_s)
    wind_u, prob_wind, w_wind = compute_weighted_marginal(wind_s, prob_s, cnt_s)

    if AUTO_SELECT_EVI:
        nseg_evi, res_evi = auto_select_segments(
            evi_u,
            prob_evi,
            w_evi,
            CANDIDATE_SEGMENTS,
            grid_step=BP_GRID_STEP,
            label="EVI"
        )
    else:
        nseg_evi = N_SEGMENTS_EVI
        bp, sl, ic, sse, np_ = fit_piecewise_grid(
            evi_u,
            prob_evi,
            w_evi,
            nseg_evi,
            grid_step=BP_GRID_STEP
        )
        res_evi = {
            "full_bp": bp,
            "slopes": sl,
            "intercepts": ic,
            "sse": sse,
            "n_params": np_
        }

    bp_evi = res_evi["full_bp"]
    slp_evi = res_evi["slopes"]
    icp_evi = res_evi["intercepts"]
    int_bp_evi = bp_evi[1:-1]

    print(f"\n  EVI 断点: {int_bp_evi}")
    print(f"  EVI 各段斜率: {[round(s, 4) for s in slp_evi]}")

    if len(int_bp_evi) > 0:
        print("  EVI Bootstrap...")
        bp_evi_med, bp_evi_lo, bp_evi_hi = bootstrap_breakpoints(
            evi_u,
            prob_evi,
            w_evi,
            nseg_evi,
            n_boot=N_BOOTSTRAP,
            ci=CI_LEVEL,
            grid_step=BP_GRID_STEP,
            label="EVI"
        )

        for k in range(len(bp_evi_med)):
            print(f"  断点 {k + 1}: {bp_evi_med[k]:.1f}  [{bp_evi_lo[k]:.1f}, {bp_evi_hi[k]:.1f}]")
    else:
        bp_evi_med = bp_evi_lo = bp_evi_hi = np.array([])

    bp_search, _, _, _, _ = fit_piecewise_grid(
        wind_u,
        prob_wind,
        w_wind,
        N_SEGMENTS_WIND_SEARCH,
        grid_step=BP_GRID_STEP
    )

    all_int_bp = bp_search[1:-1]
    kept_bp_val = float(all_int_bp[WIND_KEEP_BP_INDEX])

    print(f"\n  Wind 3 段搜索断点: {all_int_bp}")
    print(f"  保留断点 [{WIND_KEEP_BP_INDEX}] = {kept_bp_val:.1f}%")

    order_w = np.argsort(wind_u)
    wu_s = wind_u[order_w]
    pw_s = prob_wind[order_w]
    ww_s = w_wind[order_w]

    sse_w, np_w, params_w = _fit_segments_given_bp(wu_s, pw_s, ww_s, [kept_bp_val])

    bp_wind = np.array([wu_s.min(), kept_bp_val, wu_s.max()])
    slp_wind = [p[0] for p in params_w]
    icp_wind = [p[1] for p in params_w]
    int_bp_wind = np.array([kept_bp_val])
    nseg_wind = 2

    print(f"  Wind 最终断点: {int_bp_wind}")
    print(f"  Wind 各段斜率: {[round(s, 4) for s in slp_wind]}")

    print("  Wind Bootstrap...")

    n = len(wind_u)
    bp_boot = []

    for i in range(N_BOOTSTRAP):
        idx = np.random.choice(n, size=n, replace=True)

        try:
            full_bp_b, _, _, _, _ = fit_piecewise_grid(
                wind_u[idx],
                prob_wind[idx],
                w_wind[idx],
                N_SEGMENTS_WIND_SEARCH,
                grid_step=BP_GRID_STEP
            )
            bp_boot.append(float(full_bp_b[1:-1][WIND_KEEP_BP_INDEX]))
        except Exception:
            continue

        if (i + 1) % 50 == 0:
            print(f"    [Wind] bootstrap {i + 1}/{N_BOOTSTRAP}  (success: {len(bp_boot)})")

    if len(bp_boot) < 30:
        print(f"  ⚠ 仅成功 {len(bp_boot)} 次")

    bp_arr = np.array(bp_boot)
    alpha = (1 - CI_LEVEL) / 2

    bp_wind_med = np.array([np.median(bp_arr)])
    bp_wind_lo = np.array([np.percentile(bp_arr, 100 * alpha)])
    bp_wind_hi = np.array([np.percentile(bp_arr, 100 * (1 - alpha))])

    print(f"  断点: {bp_wind_med[0]:.1f}  [{bp_wind_lo[0]:.1f}, {bp_wind_hi[0]:.1f}]")

    xp_evi = np.linspace(evi_u.min(), evi_u.max(), 300)
    yp_evi = predict_piecewise(xp_evi, bp_evi, slp_evi, icp_evi)

    xp_wind = np.linspace(wind_u.min(), wind_u.max(), 300)
    yp_wind = predict_piecewise(xp_wind, bp_wind, slp_wind, icp_wind)

    pv_min = PROB_VMIN if not AUTO_COLOR_RANGE else float(prob_s.min())
    pv_max = PROB_VMAX if not AUTO_COLOR_RANGE else float(prob_s.max())
    pt_sz = size_from_counts(cnt_s, POINT_SIZE_MIN, POINT_SIZE_MAX)

    apply_nature_style()

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(FIG_W, FIG_H), dpi=DPI)

    for ax, x_s, x_u, prob_u, xp, yp, slp, icp, bp_full, int_bp, bp_md, bp_lo, bp_hi, xlabel, leg_loc, nseg_val in [
        (
            ax1,
            evi_s,
            evi_u,
            prob_evi,
            xp_evi,
            yp_evi,
            slp_evi,
            icp_evi,
            bp_evi,
            int_bp_evi,
            bp_evi_med,
            bp_evi_lo,
            bp_evi_hi,
            "Event-Mean EVI Percentile (%)",
            "upper right",
            nseg_evi
        ),
        (
            ax2,
            wind_s,
            wind_u,
            prob_wind,
            xp_wind,
            yp_wind,
            slp_wind,
            icp_wind,
            bp_wind,
            int_bp_wind,
            bp_wind_med,
            bp_wind_lo,
            bp_wind_hi,
            "Event-Mean Wind Percentile (%)",
            "upper left",
            nseg_wind
        ),
    ]:
        sc = ax.scatter(
            x_s,
            prob_s,
            c=prob_s,
            s=pt_sz,
            cmap=SCATTER_CMAP,
            vmin=pv_min,
            vmax=pv_max,
            alpha=POINT_ALPHA,
            linewidths=0.3,
            edgecolors="#555555",
            zorder=2
        )

        ax.scatter(
            x_u,
            prob_u,
            s=28,
            color="black",
            zorder=4,
            label="Weighted marginal mean"
        )

        ax.plot(
            xp,
            yp,
            color="#D62728",
            lw=2.4,
            zorder=5,
            label=f"Piecewise fit ({nseg_val} seg)"
        )

        for k, bx in enumerate(int_bp):
            ax.axvline(
                bx,
                color="#D62728",
                ls="--",
                lw=1.0,
                alpha=0.85,
                zorder=5,
                label=f"BP = {bx:.1f}%" if k == 0 else None
            )

            if len(bp_lo) > k:
                ax.axvspan(
                    bp_lo[k],
                    bp_hi[k],
                    color="#D62728",
                    alpha=0.08,
                    zorder=1
                )

        y_data_max = max(prob_u.max(), yp.max()) if len(prob_u) > 0 else yp.max()

        for si, sl_val in enumerate(slp):
            seg_lo = bp_full[si]
            seg_hi = bp_full[si + 1]
            mx = 0.5 * (seg_lo + seg_hi)
            my = icp[si] + sl_val * mx

            if sl_val >= 0:
                oy = 22
                va = "bottom"
            else:
                oy = -22
                va = "top"

            if my > 0.85 * y_data_max and oy > 0:
                oy = -14
                va = "top"

            sign = "+" if sl_val >= 0 else ""

            ax.annotate(
                f"slope = {sign}{sl_val:.3f}",
                xy=(mx, my),
                xytext=(0, oy),
                textcoords="offset points",
                fontsize=8,
                fontweight="bold",
                color="#D62728",
                ha="center",
                va=va,
                arrowprops=dict(
                    arrowstyle="-",
                    color="#D62728",
                    lw=0.6,
                    alpha=0.5
                ),
                bbox=dict(
                    boxstyle="round,pad=0.25",
                    fc="white",
                    ec="#D62728",
                    lw=0.5,
                    alpha=0.85
                )
            )

        format_panel(ax, xlabel, "Probability (%)")
        ax.set_ylim(bottom=0)

        ax.legend(
            loc=leg_loc,
            frameon=True,
            framealpha=0.92,
            edgecolor="#AAAAAA",
            fontsize=8.5,
            handletextpad=0.5,
            borderpad=0.5
        )

    plt.subplots_adjust(left=0.07, right=0.90, bottom=0.13, top=0.93, wspace=0.13)

    cax = fig.add_axes([0.915, 0.16, 0.018, 0.72])
    cb = fig.colorbar(sc, cax=cax, extend="both")
    cb.set_label("", fontsize=11, labelpad=7)
    cb.ax.tick_params(labelsize=10, width=0.8, length=3.5)
    cb.outline.set_linewidth(0.8)

    if SAVE_FIG:
        plt.savefig(OUTPUT_PNG, dpi=DPI)
        plt.savefig(OUTPUT_PDF, dpi=DPI)
        print(f"\n✓ {OUTPUT_PNG}")
        print(f"✓ {OUTPUT_PDF}")

    if SHOW_FIG:
        plt.show()

    plt.close(fig)
    print("完成。")


if __name__ == "__main__":
    main()